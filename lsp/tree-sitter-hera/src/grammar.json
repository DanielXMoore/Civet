{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "hera",
  "word": "identifier",
  "rules": {
    "program": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_line"
      }
    },
    "_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "handler_line"
        },
        {
          "type": "SYMBOL",
          "name": "newline"
        },
        {
          "type": "SYMBOL",
          "name": "_hera_items"
        }
      ]
    },
    "_hera_items": {
      "type": "PREC_LEFT",
      "value": 0,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "SYMBOL",
          "name": "_item"
        }
      }
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "code_block"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "regex"
        },
        {
          "type": "SYMBOL",
          "name": "character_class"
        },
        {
          "type": "SYMBOL",
          "name": "type_marker"
        },
        {
          "type": "SYMBOL",
          "name": "inline_handler"
        },
        {
          "type": "SYMBOL",
          "name": "arrow"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "operator"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "punctuation"
        }
      ]
    },
    "inline_handler": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "arrow"
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "SYMBOL",
            "name": "inline_handler_content"
          }
        }
      ]
    },
    "inline_handler_content": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "newline": {
      "type": "PATTERN",
      "value": "\\n+"
    },
    "_indent": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "\\n+"
          },
          {
            "type": "PATTERN",
            "value": "[ \\t]{4,}"
          }
        ]
      }
    },
    "handler_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "SYMBOL",
            "name": "handler_content"
          }
        }
      ]
    },
    "handler_content": {
      "type": "PATTERN",
      "value": "[^\\n]*"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": "[^\\r\\n]*"
          }
        ]
      }
    },
    "code_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "```"
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "SYMBOL",
            "name": "code_body"
          }
        },
        {
          "type": "STRING",
          "value": "```"
        }
      ]
    },
    "code_body": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "(?:[^`]|`[^`]|``[^`])*"
      }
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "PATTERN",
            "value": "(?:[^\"\\\\\\n]|\\\\[^\\n])*"
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "regex": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "/"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^\\s/\\\\]"
              },
              {
                "type": "PATTERN",
                "value": "\\\\[^\\n]"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "(?:[^/\\\\\\n]|\\\\[^\\n])*"
          },
          {
            "type": "STRING",
            "value": "/"
          }
        ]
      }
    },
    "character_class": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "["
          },
          {
            "type": "PATTERN",
            "value": "(?:[^\\]\\\\\\n]|\\\\[^\\n])*"
          },
          {
            "type": "STRING",
            "value": "]"
          },
          {
            "type": "PATTERN",
            "value": "[?+*]?"
          }
        ]
      }
    },
    "type_marker": {
      "type": "STRING",
      "value": "::"
    },
    "arrow": {
      "type": "STRING",
      "value": "->"
    },
    "operator": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "/"
          },
          {
            "type": "STRING",
            "value": "+"
          },
          {
            "type": "STRING",
            "value": "*"
          },
          {
            "type": "STRING",
            "value": "?"
          },
          {
            "type": "STRING",
            "value": "&"
          },
          {
            "type": "STRING",
            "value": "!"
          },
          {
            "type": "STRING",
            "value": "$"
          },
          {
            "type": "STRING",
            "value": ":"
          },
          {
            "type": "STRING",
            "value": "|"
          }
        ]
      }
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[0-9]+(?:\\.[0-9]+)?"
      }
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[_a-zA-Z][_a-zA-Z0-9]*"
    },
    "punctuation": {
      "type": "PATTERN",
      "value": "[(){}\\[\\];.,]"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}