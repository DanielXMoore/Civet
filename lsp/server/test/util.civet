// TODO: figure out the magic ts-note/TypeScript config to make this work without destructuring from default import
{ collectCommentTokens, intersectRanges, containsRange, makeRange, remapPosition, remapPositionStrict, forwardMap } from ../source/lib/util.civet
{ TextDocument } from vscode-languageserver-textdocument
assert from assert
Civet from @danielx/civet

describe "util", ->
  it "should intersect ranges", ->
    range1 := makeRange(0, 0, 0, 10)
    range2 := makeRange(0, 5, 0, 8)
    assert(intersectRanges(range1, range2))

  it "should use b.start when b begins on a later line", ->
    // exercises lines 240-241: resultStartLineNumber < otherStartLineNumber
    a := makeRange(0, 0, 5, 0)
    b := makeRange(2, 3, 5, 0)
    result := intersectRanges(a, b)
    assert(result)
    assert.equal result!.start.line, 2
    assert.equal result!.start.character, 3

  it "should use b.end when b ends on an earlier line", ->
    // exercises lines 246-247: resultEndLineNumber > otherEndLineNumber
    a := makeRange(0, 0, 5, 0)
    b := makeRange(0, 0, 3, 0)
    result := intersectRanges(a, b)
    assert(result)
    assert.equal result!.end.line, 3

  it "should check containsRange", ->
    assert containsRange

  it "should remap source positions", ->
    src := """
      x := a + 3
      y++

      y = x + a
    """

    {sourceMap} := await Civet.compile(src, {
      filename: "test.civet",
      sourceMap: true
    })

    linesMap := sourceMap.lines
    // console.log code, linesMap

    assert.deepEqual remapPosition({
      line: 0
      character: 7
    }, linesMap), { line: 0, character: 1}
    assert.deepEqual remapPosition({
      line: 1
      character: 1
    }, linesMap), { line: 1, character: 1}

  it "should return original position when no sourcemap mapping found", ->
    // exercises the fallback return at line 325-326: foundLine stays -1
    pos := { line: 5, character: 3 }
    result := forwardMap([], pos)
    assert.deepEqual result, pos

  it "should not map trimmed implicit-call whitespace onto the first argument", ->
    src := "buffer.copyToChannel data, 0\n"

    {code, sourceMap} := await Civet.compile(src, {
      filename: "test.civet"
      sourceMap: true
    })

    generatedDataColumn := code.indexOf("data")
    assert generatedDataColumn >= 0, `expected generated code to contain data; got ${code}`

    assert.deepEqual remapPositionStrict({
      line: 0
      character: generatedDataColumn
    }, sourceMap.lines), {
      line: 0
      character: src.indexOf("data")
    }

  it "should forward map", ->
    src := '''
      if signal := signals.get funcName
        ;
    '''

    {code, sourceMap} := await Civet.compile(src, {
      filename: "test.civet",
      sourceMap: true
    })

    linesMap := sourceMap.lines
    generatedLines := code.split("\n")

    [0..6].forEach (i) ->
      srcColumn := i + 13
      pos := forwardMap(linesMap, {line: 0, character: srcColumn})
      srcStr := src.slice(srcColumn, srcColumn + 7)
      assert.equal srcStr.replace(" ", "("), generatedLines[pos.line].slice(pos.character, pos.character + 7)

  it "should forward map @ shorthand", ->
    // When user types @bar in a class method, @ maps to `this.` in TypeScript.
    // The cursor after @ (at the 'b' position) should map to 'b' in `this.bar`.
    src := '''
      class Foo
        bar := 42
        foo()
          @bar
    '''

    {code, sourceMap} := await Civet.compile(src, {
      filename: "test.civet",
      sourceMap: true
    })

    linesMap := sourceMap.lines
    generatedLines := code.split("\n")

    // In Civet, `@` is at col 4, `b` is at col 5 on line 3
    // In generated TS, `b` of `this.bar` should be at col 16 (after `this.`)
    posAtB := forwardMap(linesMap, {line: 3, character: 5})
    assert.equal generatedLines[posAtB.line].slice(posAtB.character, posAtB.character + 3), "bar",
      "cursor at 'b' in @bar should map to 'b' in this.bar"

    // When @ is typed alone (trigger character), Civet transpiles to `this` (no dot).
    // The cursor after @ maps to inside `this` due to limited sourcemap entries.
    src2 := '''
      class Foo
        bar := 42
        foo()
          @
    '''

    {code: code2, sourceMap: sourceMap2} := await Civet.compile(src2, {
      filename: "test.civet",
      sourceMap: true
    })

    linesMap2 := sourceMap2.lines
    generatedLines2 := code2.split("\n")

    // @ is at col 4, cursor after @ is at col 5
    posAfterAt := forwardMap(linesMap2, {line: 3, character: 5})
    generatedLine := generatedLines2[posAfterAt.line]
    // The generated code should contain `this` and the cursor should be near it
    // (The server detects this and adjusts to after `this`)
    assert.ok generatedLine.includes("this"),
      "generated line should contain 'this' for @ shorthand"
    assert.ok posAfterAt.character >= generatedLine.indexOf("this"),
      "cursor should be at or after 'this' in the generated code"

  it "should forward map 2", ->
    src := '''
      it "should intersect ranges", ->
        range1 := makeRange(0, 0, 0, 10)
    '''

    {code, sourceMap} := await Civet.compile(src, {
      filename: "test.civet",
      sourceMap: true
    })

    linesMap := sourceMap.lines
    srcLines := src.split("\n")
    generatedLines := code.split("\n")

    [2..6].forEach (srcColumn, i) ->
      pos := forwardMap(linesMap, {line: 1, character: srcColumn})
      srcStr := srcLines[1].slice(srcColumn, srcColumn + 5 - i)
      generatedStr := generatedLines[pos.line].slice(pos.character, pos.character + 5 - i)
      assert.equal srcStr, generatedStr

  describe "collectCommentTokens", ->
    makeDoc := (text: string) =>
      TextDocument.create "file:///t.civet", "civet", 0, text

    it "splits a comment by `\\n` line breaks", ->
      // src: 'x\n# a\n# b\n' — comment range covers the two `# …` lines.
      doc := makeDoc "x\n# a\n# b\n"
      tokens := collectCommentTokens doc, [{ pos: 2, length: 7 }], 12
      assert.deepEqual tokens, [
        { line: 1, character: 0, length: 3, tokenType: 12, tokenModifiers: 0 }
        { line: 2, character: 0, length: 3, tokenType: 12, tokenModifiers: 0 }
      ]

    it "returns no tokens when commentRanges is undefined", ->
      // After a parse error the meta can carry transpiledDoc but undefined
      // commentRanges; the helper treats that as empty so the LSP server
      // doesn't need its own `?? []` defaulting branch.
      doc := makeDoc "x\n# a\n"
      assert.deepEqual collectCommentTokens(doc, undefined, 12), []

    it "splits a comment by `\\r\\n` line breaks (Windows)", ->
      // Exercises the `start = tokenEnd + 2` arm — never hit by Linux CI.
      doc := makeDoc "x\r\n# a\r\n# b\r\n"
      tokens := collectCommentTokens doc, [{ pos: 3, length: 8 }], 12
      assert.equal tokens.length, 2
      assert.equal tokens[0].line, 1
      assert.equal tokens[0].character, 0
      assert.equal tokens[0].length, 3
      assert.equal tokens[1].line, 2
      assert.equal tokens[1].character, 0
      assert.equal tokens[1].length, 3
