import TSService from "../source/lib/typescript-service.civet"
{ createBrowserTSService } from "../source/lib/typescript-service-browser.civet"
import { pathToFileURL } from "url"
import { TextDocument } from "vscode-languageserver-textdocument"
import fs from "fs"
import { mkdtempSync, writeFileSync, rmSync } from "fs"
import { tmpdir } from "os"
import path from "path"
import ts from "typescript"
{ createDefaultMapFromNodeModules, createSystem } from "@typescript/vfs"

{
  makeCivetPlugin
  makeHeraPlugin
  makeIncrementalTypecheckProgram
  TSService as SharedTSService
  createInMemoryDocFactory
} from "@danielx/civet/ts-service"
{ URI } from "vscode-uri"
{ forwardMap, getCanonicalFileName } from ../source/lib/util.civet

assert from assert

nullLogger :=
  log: ->
  info: ->
  error: ->

bundledCivetMain := path.resolve("../../dist/main.js")
bundledCivetConfig := path.resolve("../../dist/config.js")

loadFile := (service: Awaited<ReturnType<typeof TSService>>, path: string) ->
  document := TextDocument.create(pathToFileURL(path).href, "civet", 0, fs.readFileSync(path, "utf8"))
  service.host.addOrUpdateDocument(document)

projectURL := pathToFileURL("./integration/project-test/").href
aPath := "./integration/project-test/a.civet"
bPath := "./integration/project-test/b.civet"

describe "ts service", ->
  it "should launch ts service", async ->
    service := await TSService(projectURL, nullLogger)
    await service.loadPlugins()

    loadFile(service, aPath)

    diagnostics := service.getSemanticDiagnostics(aPath + ".tsx")

    assert.equal diagnostics.length, 0

    { transpiledDoc, sourcemapLines } := service.host.getMeta(aPath)!
    assert sourcemapLines

    position := transpiledDoc!.offsetAt forwardMap(sourcemapLines, {
      line: 0
      character: 0
    })
    info := service.getQuickInfoAtPosition(aPath + ".tsx", position)

    assert info

describe "ts service features", ->
  service .= null as any as Awaited<ReturnType<typeof TSService>>

  before async ->
    service = await TSService(projectURL, nullLogger)
    await service.loadPlugins()
    loadFile(service, aPath)
    loadFile(service, bPath)

  it "should go to definition cross-file", async ->
    { transpiledDoc, sourcemapLines } := service.host.getMeta(aPath)!
    assert sourcemapLines

    // "b" is at character 0 on line 0 of a.civet: `b, {b as b2} from ./b.civet`
    offset := transpiledDoc!.offsetAt forwardMap(sourcemapLines, {line: 0, character: 0})
    defs := service.getDefinitionAtPosition(aPath + ".tsx", offset)
    assert defs?.length

    rawName := service.getSourceFileName(defs![0].fileName)
    assert rawName.endsWith("b.civet"), `expected definition in b.civet, got ${rawName}`

  it "should return completions at console.", async ->
    { transpiledDoc, sourcemapLines } := service.host.getMeta(aPath)!
    assert sourcemapLines

    src := fs.readFileSync(aPath, "utf8")
    lines := src.split("\n")
    consoleLine := lines.findIndex (l) => l.includes("console.log")
    consoleCol := lines[consoleLine].indexOf("console.") + "console.".length
    offset := transpiledDoc!.offsetAt forwardMap(sourcemapLines, {line: consoleLine, character: consoleCol})
    completions := service.getCompletionsAtPosition(aPath + ".tsx", offset, {})

    assert completions?.entries.some .name is "log"

  it "should detect type errors and map to civet positions", async ->
    // Use absolute path so addOrUpdateDocument and getMeta agree on the key
    errorPath := path.resolve("./integration/project-test/error.civet")
    errorDoc := TextDocument.create(pathToFileURL(errorPath).href, "civet", 0, 'x: number := "not a number"')
    service.host.addOrUpdateDocument(errorDoc)
    diagnostics := service.getSemanticDiagnostics(errorPath + ".tsx")

    assert diagnostics.length > 0

    // Verify it's the right error
    msg := diagnostics[0].messageText <? "string"
      ? diagnostics[0].messageText
      : diagnostics[0].messageText.messageText
    assert.match msg, /not assignable/
    // Verify sourcemap lines are populated (needed for diagnostic remapping)
    { sourcemapLines } := service.host.getMeta(errorPath)!

    assert sourcemapLines

  it "should compute change range when a civet file is updated", ->
    absPath := path.resolve(aPath)
    transpiledPath := absPath + ".tsx"

    // First snapshot
    snap1 := service.host.getScriptSnapshot(transpiledPath)
    assert snap1, "expected first snapshot"

    // Prepend a comment so the transpiled output differs from the start
    // (avoids the "prefix-only" case where fullDiffTextChangeRange returns undefined)
    origContent := fs.readFileSync(absPath, "utf8")
    updatedDoc := TextDocument.create(pathToFileURL(absPath).href, "civet", 1, "// extra\n" + origContent)
    service.host.addOrUpdateDocument(updatedDoc)

    // Second snapshot — new Snap instance with updated transpiled text
    snap2 := service.host.getScriptSnapshot(transpiledPath)
    assert snap2, "expected second snapshot"
    assert.notStrictEqual snap2, snap1

    // Exercises fullDiffTextChangeRange and Snap.getChangeRange (also createOrUpdateMeta update branch)
    changeRange := snap2.getChangeRange(snap1)
    assert changeRange, "expected a defined change range when content differs from the start"
    assert.ok changeRange!.span.start >= 0
    assert.ok changeRange!.newLength >= 0

    // Calling again returns the cached result
    assert.strictEqual snap2.getChangeRange(snap1), changeRange

  it "should add a non-transpiled ts document without error", ->
    tsPath := path.resolve("./integration/project-test/t.ts")
    tsDoc := TextDocument.create(pathToFileURL(tsPath).href, "typescript", 0, "const x = 1")
    service.host.addOrUpdateDocument(tsDoc)
    // No transpiler for .ts — exercises the plain-document branch

  it "should return undefined meta for a plain ts path", ->
    tsPath := path.resolve("./integration/project-test/t.ts")
    meta := service.host.getMeta(tsPath)
    // No meta recorded for non-transpiled files — exercises getTranspiledPath fallback
    assert.equal meta, undefined

  it "should call writeFile without error", ->
    service.host.writeFile!("out.js", "const x = 1;")
    // writeFile just delegates to logger.log; no assertion needed beyond no throw

  it "should return original filename when target extension does not match transpiler target", ->
    // .civet transpiler targets .tsx; passing .civet.js means target (.js) != .tsx
    // so remapFileName falls through to the final return (line 557)
    result := service.getSourceFileName("foo.civet.js")
    assert.equal result, "foo.civet.js"

  it "should return undefined change range when snapshots have identical text", ->
    // Getting the same cached snapshot and calling getChangeRange on itself
    // exercises fullDiffTextChangeRange(text, text) → all chars match → return undefined (line 586)
    transpiledPath := path.resolve(aPath) + ".tsx"
    snap := service.host.getScriptSnapshot(transpiledPath)
    assert snap

    result := snap!.getChangeRange(snap!)
    assert.equal result, undefined

  it "should compute change range when content changes in the middle", ->
    // Two civet snapshots differing only in the middle (shared prefix and suffix)
    // exercises the break in the suffix-scan loop (line 572)
    snapPath := path.resolve("./integration/project-test/snap-test.civet")
    snapTranspiledPath := snapPath + ".tsx"

    doc1 := TextDocument.create(pathToFileURL(snapPath).href, "civet", 0, "x := 1")
    service.host.addOrUpdateDocument(doc1)
    snap1 := service.host.getScriptSnapshot(snapTranspiledPath)

    assert snap1

    doc2 := TextDocument.create(pathToFileURL(snapPath).href, "civet", 1, "x := 2")
    service.host.addOrUpdateDocument(doc2)
    snap2 := service.host.getScriptSnapshot(snapTranspiledPath)

    assert snap2
    assert.notStrictEqual snap1, snap2

    // "const x = 1;" vs "const x = 2;" — common suffix ";" hits break after one match
    changeRange := snap2!.getChangeRange(snap1!)

    assert changeRange, "expected a change range for middle-of-string diff"
    assert changeRange!.span.start >= 0

  it "should store fatal parse error in meta when transpiler throws", ->
    // Null bytes cause Civet.compile to throw rather than returning errors in the array
    // exercises the catch block in doTranspileAndUpdateMeta (lines 352-355)
    errorPath := path.resolve("./integration/project-test/throw-test.civet")
    throwDoc := TextDocument.create(pathToFileURL(errorPath).href, "civet", 0, "\x00invalid")
    service.host.addOrUpdateDocument(throwDoc)
    meta := service.host.getMeta(errorPath)

    assert meta, "expected meta to be recorded after a compile throw"
    assert meta!.fatal, "expected fatal=true when compile throws"
    assert meta!.parseErrors?.length, "expected parse errors to be recorded"

describe "ts service document lifecycle", ->
  it "closeDocument should drop editor doc but keep civet file in project", ->
    // Mirrors LSP didClose: editor tab closed, file still on disk.
    // Editor-tied caches must clear so next read falls back to disk,
    // but scriptFileNames must keep the transpiled path since other
    // open files may still import this one.
    service := await TSService(projectURL, nullLogger)
    await service.loadPlugins()

    civetPath := path.resolve("./integration/project-test/close-test.civet")
    transpiledPath := civetPath + ".tsx"
    doc := TextDocument.create(pathToFileURL(civetPath).href, "civet", 0, "x := 1")
    service.host.addOrUpdateDocument(doc)
    // Prime caches
    preMeta := service.host.getMeta(civetPath)
    assert preMeta, "precondition: meta should exist after add"

    service.host.closeDocument(civetPath)

    assert.equal service.host.getScriptVersion(civetPath), "0",
      "source editor doc should be forgotten after close"
    assert service.host.getScriptFileNames().includes(getCanonicalFileName transpiledPath),
      "transpiled path should remain in scriptFileNames after close (file may still be imported)"

  it "removeDocument should fully drop civet doc from project", ->
    // Mirrors file deletion: file no longer exists on disk, drop everything.
    service := await TSService(projectURL, nullLogger)
    await service.loadPlugins()

    civetPath := path.resolve("./integration/project-test/remove-test.civet")
    transpiledPath := civetPath + ".tsx"
    doc := TextDocument.create(pathToFileURL(civetPath).href, "civet", 0, "x := 1")
    service.host.addOrUpdateDocument(doc)
    service.host.getMeta(civetPath)  // prime caches

    service.host.removeDocument(civetPath)

    assert.equal service.host.getScriptVersion(civetPath), "0",
      "source path should be forgotten after removeDocument"
    assert.equal service.host.getScriptVersion(transpiledPath), "0",
      "transpiled path should be forgotten after removeDocument"
    assert not service.host.getScriptFileNames().includes(getCanonicalFileName transpiledPath),
      "transpiled path should be removed from scriptFileNames"

  it "closeDocument should keep plain ts file in scriptFileNames", ->
    service := await TSService(projectURL, nullLogger)
    await service.loadPlugins()

    tsPath := path.resolve("./integration/project-test/close-plain.ts")
    doc := TextDocument.create(pathToFileURL(tsPath).href, "typescript", 0, "const x = 1")
    service.host.addOrUpdateDocument(doc)

    service.host.closeDocument(tsPath)

    assert service.host.getScriptFileNames().includes(getCanonicalFileName tsPath),
      "plain ts file should remain in scriptFileNames after close"
    assert.equal service.host.getScriptVersion(tsPath), "0",
      "editor doc for plain ts should be forgotten after close"

  it "removeDocument should drop plain ts file from scriptFileNames", ->
    service := await TSService(projectURL, nullLogger)
    await service.loadPlugins()

    tsPath := path.resolve("./integration/project-test/remove-plain.ts")
    doc := TextDocument.create(pathToFileURL(tsPath).href, "typescript", 0, "const x = 1")
    service.host.addOrUpdateDocument(doc)

    assert service.host.getScriptFileNames().includes(getCanonicalFileName tsPath),
      "precondition: plain ts should be in scriptFileNames"

    service.host.removeDocument(tsPath)

    assert not service.host.getScriptFileNames().includes(getCanonicalFileName tsPath),
      "plain ts should be removed from scriptFileNames"
    assert.equal service.host.getScriptVersion(tsPath), "0",
      "plain ts path should be forgotten after removeDocument"

describe "ts service module resolution", ->
  it "resolves a directory import via index.civet", async ->
    // Exercises resolveModuleNames + resolvedModule's index-file lookup
    // (typescript-service.civet lines 131-137) where transpiler is picked up
    // from the implicit `<dir>/index.civet` file for a directory import.
    service := await TSService(projectURL, nullLogger)
    await service.loadPlugins()

    dirImportPath := path.resolve("./integration/project-test/dir-import.civet")
    loadFile(service, dirImportPath)
    // Semantic diagnostics force TS to resolve `./lib` which hits the
    // directory-import branch that scans for `index + transpiler.extension`.
    diagnostics := service.getSemanticDiagnostics(dirImportPath + ".tsx")
    assert.equal diagnostics.length, 0,
      `expected no diagnostics, got ${diagnostics.map(.messageText).join(", ")}`

  it "accepts a plain filesystem path (not a file:// URL) as projectURL", async ->
    // Exercises line 434: projectURL.startsWith("file:") ? ... : path.resolve(projectURL)
    // (the else branch that normalizes a bare path).
    plainPath := path.resolve("./integration/project-test") + path.sep
    service := await TSService(plainPath, nullLogger)
    await service.loadPlugins()
    // Constructing the service and loading plugins is enough to cover
    // the path-normalization else branch.
    assert service

  it "takes the pathsBasePath fallback when baseUrl is unset", async ->
    // Exercises the right side of `pathsBase := baseUrl ?? (pathsBasePath ...)`
    // at typescript-service.civet line 158.  TS 5.0+ allows `paths` without an
    // explicit `baseUrl`; parseJsonConfigFileContent sets options.pathsBasePath
    // to the tsconfig's directory, so our fallback chain lands on pathsBasePath.
    //
    // We only need resolveModuleNames to *run* the fallback branch — the import
    // itself doesn't have to resolve.  An unresolvable alias import triggers
    // the paths loop (covering the `baseUrl ??` right side), then TS reports
    // "Cannot find module", proving the code path executed.
    tmpDir := mkdtempSync(path.join(tmpdir(), 'civet-no-baseurl-'))
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'), JSON.stringify({
        compilerOptions:
          target: 'es2020'
          module: 'NodeNext'
          paths:
            '@missing/*': ['nowhere/*']
      })
      consumerPath := path.join(tmpDir, 'consumer.civet')
      writeFileSync consumerPath, 'x from @missing/anything\n'

      service := await TSService(pathToFileURL(tmpDir + path.sep).href, nullLogger)
      await service.loadPlugins()
      loadFile(service, consumerPath)

      // TS invokes our resolveModuleNames for `@missing/anything`, which runs
      // the paths-resolution block (the branch we're here to cover) and then
      // reports the module as unresolved.
      diagnostics := service.getSemanticDiagnostics(consumerPath + '.tsx')
      assert diagnostics.some((d) => String(d.messageText).includes("Cannot find module")),
        `expected a 'Cannot find module' diagnostic, got: ${diagnostics.map(.messageText).join(' | ')}`
    finally
      rmSync(tmpDir, { recursive: true, force: true })

describe "ts service without civet dependencies", ->
  let tmpDir: string
  before ->
    tmpDir = mkdtempSync(path.join(tmpdir(), 'civet-lsp-bundled-'))
    writeFileSync path.join(tmpDir, 'tsconfig.json'), '{"compilerOptions":{"target":"es2020"}}'

  after ->
    rmSync(tmpDir, { recursive: true, force: true }) if tmpDir

  it "falls back to bundled civet when the project can't resolve @danielx/civet", async ->
    // Exercises lines 486-487 (USING BUNDLED CIVET) + 496-497 (No Civet config found).
    // `tmpDir` has no node_modules, so projectRequire('@danielx/civet') throws,
    // and findConfig walks up without finding a civetconfig.
    service := await TSService(tmpDir + path.sep, nullLogger)
    await service.loadPlugins()
    // Service should still be usable after bundled fallback
    assert service

  it "logs an error when civet config fails to load", async ->
    // Exercises the catch arm at line 498-499: CivetConfig.loadConfig throws
    // on a malformed civetconfig.json.
    badConfigDir := mkdtempSync(path.join(tmpdir(), 'civet-lsp-badcfg-'))
    try
      writeFileSync path.join(badConfigDir, 'tsconfig.json'), '{"compilerOptions":{"target":"es2020"}}'
      writeFileSync path.join(badConfigDir, 'civetconfig.json'), '{"not valid json'
      errors: string[] := []
      capturingLogger := {
        log: ->
        info: ->
        error: (msg: string) => errors.push msg
      }
      service := await TSService(badConfigDir + path.sep, capturingLogger)
      await service.loadPlugins()
      assert service
      assert errors.some((e) => e.includes("Error loading Civet config")),
        `expected config error, got: ${errors.join(" | ")}`
    finally
      rmSync(badConfigDir, { recursive: true, force: true })

describe "ts service with partial project civet packages", ->
  tmpDirs: string[] := []

  after ->
    for tmpDir of tmpDirs
      rmSync tmpDir, { recursive: true, force: true }

  writeFakeProjectCivet := (options: { version: string, includeLib?: boolean, includeConfig?: boolean }) ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-lsp-partial-project-'
    tmpDirs.push tmpDir

    writeFileSync path.join(tmpDir, 'tsconfig.json'),
      '{"compilerOptions":{"target":"es2020"}}'
    samplePath := path.join tmpDir, 'sample.civet'
    writeFileSync samplePath, '// comment\nx := 1\n'

    packageDir := path.join tmpDir, 'node_modules', '@danielx', 'civet'
    fs.mkdirSync packageDir, recursive: true
    exports: Record<string, string> :=
      '.': './index.cjs'
      './package.json': './package.json'
    exports['./config'] = './config.js' if options.includeConfig ?? true
    writeFileSync path.join(packageDir, 'package.json'), JSON.stringify {}
      name: '@danielx/civet'
      version: options.version
      main: 'index.cjs'
      exports

    if options.includeConfig ?? true
      writeFileSync path.join(packageDir, 'config.js'),
        `module.exports = require(${JSON.stringify bundledCivetConfig});\n`

    if options.includeLib ?? true
      writeFileSync path.join(packageDir, 'index.cjs'),
        `module.exports = require(${JSON.stringify bundledCivetMain});\n`
    else
      writeFileSync path.join(packageDir, 'index.cjs'), ```
        const real = require(${JSON.stringify bundledCivetMain});
        const { lib, ...rest } = real;
        module.exports = rest;
      ```

    { tmpDir, samplePath }

  it "falls back to bundled lib when project civet is missing lib export", async ->
    { tmpDir, samplePath } := writeFakeProjectCivet
      version: '0.11.7'
      includeLib: false

    errors: string[] := []
    capturingLogger :=
      log: ->
      info: ->
      error: (msg: string) => errors.push msg

    service := await TSService(pathToFileURL(tmpDir + path.sep).href, capturingLogger)
    loadFile(service, samplePath)
    meta := service.host.getMeta(samplePath)

    assert meta?.commentRanges?.length, 'expected bundled lib fallback to collect comment ranges'
    assert errors.some((msg) => msg.includes('MISSING lib EXPORT')),
      `expected missing lib warning, got: ${errors.join(' | ')}`

  it "logs the missing config module when project civet is missing config module", async ->
    { tmpDir } := writeFakeProjectCivet
      version: '0.11.7'
      includeConfig: false

    infos: string[] := []
    capturingLogger :=
      log: ->
      info: (msg: string) => infos.push msg
      error: ->

    service := await TSService(pathToFileURL(tmpDir + path.sep).href, capturingLogger)
    await service.loadPlugins()

    assert service
    assert infos.some((msg) => msg.includes('PROJECT CIVET 0.11.7 IS MISSING CONFIG MODULE')),
      `expected missing config log, got: ${infos.join(' | ')}`

  it "uses the legacy compile path when project civet predates 0.9.4", async ->
    { tmpDir, samplePath } := writeFakeProjectCivet
      version: '0.9.3'

    service := await TSService(pathToFileURL(tmpDir + path.sep).href, nullLogger)
    loadFile(service, samplePath)
    meta := service.host.getMeta(samplePath)

    assert meta?.sourcemapLines, 'expected legacy compile path to populate sourcemap lines'
    assert.equal meta?.commentRanges, undefined,
      'legacy compile path should not collect comment ranges even when the input contains comments'

describe "ts service hera plugin", ->
  hPath := "./integration/project-test/h.hera"

  it "transpiles a .hera file via the built-in hera plugin", async ->
    // Note: skip loadPlugins() — the project-test fixture ships its own
    // hera-plugin.mjs that targets .cjs and skips sourcemaps; that's a fixture
    // for the plugin-loading flow, not the built-in Hera transpiler we want
    // to exercise here.
    service := await TSService(projectURL, nullLogger)

    heraDoc := TextDocument.create(pathToFileURL(hPath).href, "hera", 0, fs.readFileSync(hPath, "utf8"))
    service.host.addOrUpdateDocument(heraDoc)

    meta := service.host.getMeta(hPath)
    assert meta, `expected meta for ${hPath}`

    { transpiledDoc, sourcemapLines, parseErrors, fatal } := meta!
    assert.equal fatal, false, 'transpile should not be fatal'
    assert.equal parseErrors?.length ?? 0, 0, 'no parse errors expected'
    assert sourcemapLines, 'expected sourcemap lines'
    assert transpiledDoc, 'expected transpiledDoc'
    assert transpiledDoc!.getText().length > 0, 'expected non-empty transpiled output'

    // The composed Hera→Civet→TS sourcemap should let us walk back from any
    // TS-coordinate diagnostic to the original .hera source.  No assertion on
    // semantic-diagnostic count here — Hera-generated TS imports from
    // `@danielx/hera/lib` whose .d.ts shape may evolve; we only require that
    // compilation reaches semantic analysis at all.
    diagnostics := service.getSemanticDiagnostics(hPath + ".tsx")
    assert Array.isArray(diagnostics), 'getSemanticDiagnostics should return an array'

describe "ts-service plugin factories", ->
  // makeCivetPlugin / makeHeraPlugin are exposed as part of the public
  // @danielx/civet/ts-service API; the LSP and unplugin always pass an
  // explicit Civet module + config, but standalone consumers (CLI typecheck,
  // ad-hoc scripts) can call the factories with no arguments and rely on
  // the bundled Civet/Hera defaults.  These tests exercise that path so
  // the `?? Bundled…` fallbacks (and the Hera plugin's compile error path)
  // stay covered.

  it "makeCivetPlugin() with no options uses bundled defaults", ->
    plugin := makeCivetPlugin()
    assert plugin.transpilers, "expected transpilers"
    [t] := plugin.transpilers!
    assert.equal t.extension, ".civet"
    assert.equal t.target, ".tsx"
    result := t.compile("inline.civet", "x := 5\nconsole.log x\n")
    assert result, "expected compile result"
    assert (result! as { code: string }).code.includes("const x"), "expected `const x = 5` in output"

  it "makeHeraPlugin() with no options uses bundled defaults", ->
    plugin := makeHeraPlugin()
    assert plugin.transpilers, "expected transpilers"
    [t] := plugin.transpilers!
    assert.equal t.extension, ".hera"
    assert.equal t.target, ".tsx"
    grammar := fs.readFileSync("./integration/project-test/h.hera", "utf8")
    result := t.compile("./integration/project-test/h.hera", grammar)
    assert result, "expected compile result"
    assert (result! as { code: string }).code.length > 0, "expected non-empty compiled output"

  it "makeHeraPlugin() reports parse errors via the result.errors array", ->
    // Malformed grammar — Hera throws a ParseError, which the plugin's
    // catch block converts into a result with empty code and a populated
    // errors array (so consumers can surface diagnostics rather than crash).
    plugin := makeHeraPlugin()
    [t] := plugin.transpilers!
    result := t.compile("bad.hera", "this is not a hera grammar :=:=:=\n")
    assert result, "expected compile result"
    typed := result! as { code: string, errors?: Error[] }
    assert.equal typed.code, "", "expected empty code on parse failure"
    assert typed.errors and typed.errors.length > 0, "expected at least one error"

describe "ts-service direct factory usage", ->
  // Drive the shared TSService factory directly (bypassing the LSP wrapper)
  // so the bundler-driven branches — `discoverProjectFiles: false` and
  // empty-plugins — get coverage too.

  directDocFactory := {
    create: (uri: string, languageId: string, version: number, text: string) =>
      TextDocument.create uri, languageId, version, text
    update: (doc: any, text: string, version: number) =>
      TextDocument.update doc, [{ text }], version
    uriToPath: (uri: string) => URI.parse(uri).fsPath
    pathToUri: (p: string) => URI.file(p).toString()
  }

  createVirtualSystem := (rootDir: string, libDir = path.join(rootDir, 'typescript', 'lib')) ->
    fsMap := createDefaultMapFromNodeModules({ target: ts.ScriptTarget.ES2020 }, ts)
    for [filePath, text] of Array.from fsMap
      fsMap.set path.join(libDir, filePath.slice(1)), text
    system := createSystem(fsMap)
    pathVariants := (p: string) =>
      normalized := path.normalize p
      variants := [normalized]
      if /^[A-Za-z]:/.test normalized
        variants.push normalized.replace /^[A-Za-z]:/, (drive) => drive.toLowerCase()
        variants.push normalized.replace /^[A-Za-z]:/, (drive) => drive.toUpperCase()
      Array.from new Set variants
    readFile := (p: string): string? =>
      for candidate of pathVariants p
        return system.readFile candidate if system.fileExists candidate
      return undefined
    {
      ...system
      getCurrentDirectory: => rootDir
      getExecutingFilePath: => path.join(rootDir, 'typescript.js')
      resolvePath: (p: string) => path.resolve(p)
      fileExists: (p: string) => pathVariants(p).some system.fileExists
      readFile
      directoryExists: (p: string) => pathVariants(p).some system.directoryExists
      readDirectory: (p: string, extensions?: readonly string[], excludes?: readonly string[], includes?: readonly string[], depth?: number) =>
        for candidate of pathVariants p
          if system.directoryExists candidate
            return system.readDirectory candidate, extensions, excludes, includes, depth
        []
      createHash: (data: string) => data
    }

  virtualRoot := (name: string) =>
    directDocFactory.uriToPath URI.file(path.join(path.parse(process.cwd()).root, name)).toString()

  // Trailing slash matters: TSService builds tsConfigPath as
  // `${projectPath}tsconfig.json`.
  projectPath := path.resolve("./integration/project-test/") + path.sep

  it "starts with no plugins and no auto-discovery (bundler-driven mode)", ->
    service := SharedTSService projectPath, {
      docFactory: directDocFactory
      logger: nullLogger
      discoverProjectFiles: false
    }
    program := service.getProgram()
    assert program, "expected a program even with no plugins"
    // No transpilers registered, so the program has no .civet/.hera siblings;
    // any pre-existing .ts files in the test fixture still appear as roots.
    fileNames := program!.getSourceFiles().map .fileName
    assert.equal fileNames.some(.endsWith ".civet.tsx"), false, "expected no .civet.tsx without a Civet plugin"

  it "registers plugins lazily through registerPlugin after construction", ->
    service := SharedTSService projectPath, {
      docFactory: directDocFactory
      logger: nullLogger
      discoverProjectFiles: false
    }
    // registerPlugin path is also exercised internally by `plugins: [...]`,
    // but calling it post-construction covers consumers that load plugins
    // (like loadPlugins() does for `.civet/*-plugin.mjs`).
    service.registerPlugin makeCivetPlugin()
    // Add a .civet doc and verify it now compiles via the registered plugin.
    civetPath := path.resolve "./integration/project-test/snap-test.civet"
    doc := TextDocument.create pathToFileURL(civetPath).href, "civet", 0, "x := 7\n"
    service.host.addOrUpdateDocument doc
    meta := service.host.getMeta civetPath
    assert meta?.transpiledDoc, "expected the freshly-registered Civet plugin to compile snap-test.civet"

  it "keeps standard Array methods available with a virtual system", ->
    rootDir := virtualRoot 'civet-virtual-array'
    libDir := path.join(rootDir, 'typescript', 'lib')
    system := createVirtualSystem rootDir, libDir
    service := SharedTSService rootDir, {
      plugins: [makeCivetPlugin()]
      docFactory: directDocFactory
      logger: nullLogger
      system
      libDir
      discoverProjectFiles: false
      tsConfig:
        compilerOptions:
          target: 'ES2020'
          module: 'ESNext'
          moduleResolution: 'Bundler'
          strict: true
          jsx: 'preserve'
          noEmit: true
          lib: ['ES2020']
        include: ['**/*']
    }
    source := 'z := (...xs for xs of [[1,2,3], [], [4,5]])\n'
    sourcePath := path.join rootDir, 'index.civet'
    doc := TextDocument.create URI.file(sourcePath).toString(), 'civet', 1, source
    service.host.addOrUpdateDocument doc
    diagnostics := service.getSemanticDiagnostics directDocFactory.uriToPath(doc.uri) + '.tsx'
    messages := diagnostics.map (d) => String d.messageText
    assert !messages.some((message) => message.includes("Property 'push' does not exist")),
      `expected no missing Array.push diagnostic, got: ${messages.join(' | ')}`
    assert.equal diagnostics.length, 0,
      `expected no diagnostics, got: ${messages.join(' | ')}`

  it "resolves imported Civet files from open documents before the virtual system", ->
    rootDir := virtualRoot 'civet-virtual-open-docs'
    libDir := path.join(rootDir, 'typescript', 'lib')
    system := createVirtualSystem rootDir, libDir
    service := SharedTSService rootDir, {
      plugins: [makeCivetPlugin()]
      docFactory: directDocFactory
      logger: nullLogger
      system
      libDir
      discoverProjectFiles: false
      tsConfig:
        compilerOptions:
          target: 'ES2020'
          module: 'ESNext'
          moduleResolution: 'Bundler'
          strict: true
          jsx: 'preserve'
          noEmit: true
          lib: ['ES2020']
        include: ['**/*']
    }
    otherPath := path.join rootDir, 'other.civet'
    indexPath := path.join rootDir, 'index.civet'
    assert.equal system.fileExists(otherPath), false

    service.host.addOrUpdateDocument TextDocument.create(
      URI.file(otherPath).toString()
      'civet'
      1
      'export value := 1\n'
    )
    indexDoc := TextDocument.create(
      URI.file(indexPath).toString()
      'civet'
      1
      'import { value } from "./other.civet"\nx: number := value\n'
    )
    service.host.addOrUpdateDocument indexDoc

    diagnostics := service.getSemanticDiagnostics directDocFactory.uriToPath(indexDoc.uri) + '.tsx'
    messages := diagnostics.map (d) => String d.messageText
    assert !messages.some((message) => /Cannot find module/.test message),
      `expected open imported Civet doc to resolve, got: ${messages.join(' | ')}`
    assert.equal diagnostics.length, 0,
      `expected no diagnostics, got: ${messages.join(' | ')}`

  it "browser wrapper requires Civet on globalThis", async ->
    originalCivet := (globalThis as any).Civet
    try
      delete (globalThis as any).Civet
      BrowserTSService := createBrowserTSService createVirtualSystem(virtualRoot 'civet-browser-wrapper')
      await assert.rejects(
        BrowserTSService 'file:///workspace/', nullLogger
        /requires globalThis\.Civet/
      )
    finally
      if originalCivet?
        (globalThis as any).Civet = originalCivet
      else
        delete (globalThis as any).Civet

  it "addScriptFileName widens program scope without a TranspiledDoc", ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-add-script-file-'
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'),
        '{"compilerOptions":{"target":"es2020"}}'
      sidecarPath := path.join tmpDir, 'sidecar.civet'
      writeFileSync sidecarPath, "x: number := 'wrong type'\n"

      // discoverProjectFiles=false so the file enters only via
      // addScriptFileName.
      service := SharedTSService tmpDir + path.sep, {
        plugins: [makeCivetPlugin()]
        docFactory: directDocFactory
        logger: nullLogger
        discoverProjectFiles: false
      }

      // Idempotent: second call short-circuits via scriptFileNames.has.
      service.host.addScriptFileName sidecarPath
      service.host.addScriptFileName sidecarPath

      diagnostics := service.getSemanticDiagnostics(sidecarPath + '.tsx')
      assert diagnostics.length > 0,
        "expected at least one diagnostic from sidecar.civet"
      assert diagnostics.some((d) => String(d.messageText).includes("'wrong type'") or String(d.messageText).includes("not assignable")),
        `expected a type-mismatch diagnostic, got: ${diagnostics.map(.messageText).join(' | ')}`
    finally
      rmSync tmpDir, { recursive: true, force: true }

  it "readFile passes non-package.json contents through unchanged", ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-readfile-passthrough-'
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'),
        '{"compilerOptions":{"target":"es2020"}}'
      txtPath := path.join tmpDir, 'data.txt'
      writeFileSync txtPath, 'hello world'
      // package.json with `imports` but no transpilable extensions —
      // mogrify walks the map, finds nothing to rewrite, returns
      // original contents.
      pkgJson := JSON.stringify {
        name: 'no-transpilables-fixture'
        imports: { '#plain': './data.txt' }
      }
      writeFileSync path.join(tmpDir, 'package.json'), pkgJson

      service := SharedTSService tmpDir + path.sep, {
        plugins: [makeCivetPlugin()]
        docFactory: directDocFactory
        logger: nullLogger
        discoverProjectFiles: false
      }
      // Non-package.json: pass-through.
      assert.equal service.host.readFile(txtPath), 'hello world'
      // Missing file: baseReadFile returns undefined, falls through.
      assert.equal service.host.readFile(path.join tmpDir, 'nope.txt'), undefined
      // package.json with non-transpilable imports: walked, unchanged.
      assert.equal service.host.readFile(path.join tmpDir, 'package.json'), pkgJson
    finally
      rmSync tmpDir, { recursive: true, force: true }

  it "rewrites raw .civet entries from tsconfig.files to their .tsx siblings", ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-files-array-'
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'), JSON.stringify({
        compilerOptions: { target: 'es2020' }
        files: ['main.civet']
      })
      writeFileSync path.join(tmpDir, 'main.civet'), 'x := 5\n'

      service := SharedTSService tmpDir + path.sep, {
        plugins: [makeCivetPlugin()]
        docFactory: directDocFactory
        logger: nullLogger
      }
      program := service.getProgram()
      fileNames := program!.getSourceFiles().map .fileName
      assert fileNames.some(.endsWith "main.civet.tsx"),
        `expected main.civet.tsx in program (got ${fileNames.filter(.includes 'main').join(', ')})`
    finally
      rmSync tmpDir, { recursive: true, force: true }

  it "merges consumer-supplied extraCompilerOptions on top of tsconfig", ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-extra-opts-'
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'),
        '{"compilerOptions":{"target":"es2020"}}'
      service := SharedTSService tmpDir + path.sep, {
        docFactory: directDocFactory
        logger: nullLogger
        discoverProjectFiles: false
        extraCompilerOptions:
          incremental: true
          tsBuildInfoFile: path.join(tmpDir, '.tsbuildinfo')
      }
      compilationSettings := service.host.getCompilationSettings()
      assert.equal compilationSettings.incremental, true,
        "expected extraCompilerOptions.incremental to override tsconfig"
      assert.equal compilationSettings.tsBuildInfoFile,
        path.join(tmpDir, '.tsbuildinfo'),
        "expected extraCompilerOptions.tsBuildInfoFile to flow through"
    finally
      rmSync tmpDir, { recursive: true, force: true }

  it "makeHeraPlugin honors options.Hera override", ->
    callLog: { source: string, filename: string }[] := []
    fakeHera := {
      compile: (source: string, options: { filename: string }) =>
        callLog.push { source, filename: options.filename }
        { code: "// fake hera output\n", sourceMap: { lines: [] } }
    }
    plugin := makeHeraPlugin Hera: fakeHera
    [t] := plugin.transpilers!
    result := t.compile("test.hera", "Rule := 'x'")
    assert result, "expected compile result"
    assert.equal callLog.length, 1, "expected fakeHera.compile to be called"
    assert.equal callLog[0].filename, "test.hera"
    assert (result! as { code: string }).code.includes("fake hera output"),
      "expected fakeHera output in result"

  it "package.json `imports` map redirects through to .civet sources", ->
    // TSHost rewrites transpilable extensions (`.civet`, `.hera`) inside
    // package.json's `imports` field on read, and reports the synthetic
    // `.tsx` siblings as existing via fileExists — together those let
    // TS resolve `import x from '#dep'` against a `.civet` source.
    pkgDir := mkdtempSync path.join tmpdir(), 'civet-pkg-imports-'
    try
      writeFileSync path.join(pkgDir, 'tsconfig.json'), JSON.stringify({
        compilerOptions:
          target: 'es2020'
          module: 'node16'
          moduleResolution: 'node16'
          strict: true
          skipLibCheck: true
          jsx: 'preserve'
      })
      writeFileSync path.join(pkgDir, 'package.json'), JSON.stringify({
        name: 'lsp-pkg-imports-fixture'
        type: 'module'
        imports: { '#dep': './dep.civet', '#nested': { default: './nested.civet' } }
      })
      writeFileSync path.join(pkgDir, 'dep.civet'), "export foo: string := 'hello'\n"
      writeFileSync path.join(pkgDir, 'nested.civet'), "export bar := 42\n"
      consumerPath := path.join pkgDir, 'consumer.civet'
      writeFileSync consumerPath,
        "{ foo } from '#dep'\n{ bar } from '#nested'\nx: number := foo\ny: string := bar\n"
      consumerSource := fs.readFileSync consumerPath, "utf8"

      service := SharedTSService pkgDir + path.sep, {
        plugins: [makeCivetPlugin()]
        docFactory: directDocFactory
        logger: nullLogger
      }
      doc := TextDocument.create pathToFileURL(consumerPath).href, "civet", 0, consumerSource
      service.host.addOrUpdateDocument doc

      diagnostics := service.getSemanticDiagnostics consumerPath + ".tsx"
      messages := diagnostics.map (d) => String d.messageText
      // No TS2307 — both #dep and #nested resolved.  Plus the type
      // mismatches prove the resolved sources actually flowed through.
      for missing of messages.filter (m) => m.includes "Cannot find module"
        assert false, `unexpected resolution failure: ${missing}`
      hasStringToNumber := messages.some (m) =>
        m.includes("'string' is not assignable to type 'number'") or
        m.includes("Type 'string'") and m.includes("'number'")
      hasNumberToString := messages.some (m) =>
        m.includes("'number' is not assignable to type 'string'") or
        m.includes("Type 'number'") and m.includes("'string'")
      assert hasStringToNumber, `expected string→number mismatch, got: ${messages.join(' | ')}`
      assert hasNumberToString, `expected number→string mismatch, got: ${messages.join(' | ')}`
    finally
      rmSync pkgDir, { recursive: true, force: true }

describe "createInMemoryDocFactory", ->
  // Shared in-memory factory used by typecheck.civet and unplugin (any
  // consumer that doesn't need vscode-languageserver-textdocument).  These
  // tests exercise the create/update/uri round-trip so the helper file
  // stays covered without driving a full TSService through it.

  factory := createInMemoryDocFactory()

  it "create() produces a doc satisfying TranspiledDoc", ->
    doc := factory.create "file:///x/y.civet", "civet", 3, "hello"
    assert.equal doc.uri, "file:///x/y.civet"
    assert.equal doc.version, 3
    assert.equal doc.getText(), "hello"

  it "update() mutates text + version in place", ->
    doc := factory.create "file:///x/y.civet", "civet", 0, "first"
    factory.update doc, "second", 5
    assert.equal doc.version, 5
    assert.equal doc.getText(), "second"

  it "uriToPath / pathToUri round-trip a path", ->
    p := path.resolve "./integration/project-test/a.civet"
    uri := factory.pathToUri p
    assert uri.startsWith "file://"
    assert.equal factory.uriToPath(uri), p

describe "makeIncrementalTypecheckProgram", ->
  // The incremental typecheck path bypasses LanguageService; these
  // tests stand it up against a tiny on-disk project so the
  // CompilerHost overrides (getSourceFile / fileExists /
  // resolveModuleNameLiterals) and the BuilderProgram cache flow are
  // covered without depending on `civet --typecheck` running in CI.

  it "compiles a clean project to an EmitAndSemanticDiagnosticsBuilderProgram", ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-incremental-clean-'
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'),
        '{"compilerOptions":{"target":"es2020","strict":true,"jsx":"preserve"},"include":["**/*.civet"]}'
      civetPath := path.join tmpDir, 'main.civet'
      writeFileSync civetPath, "x: number := 5\nconsole.log x\n"

      { builder, getMeta, configErrors } := makeIncrementalTypecheckProgram tmpDir, {
        plugins: [makeCivetPlugin()]
      }
      assert.equal configErrors.length, 0, "tsconfig should parse cleanly"

      program := builder.getProgram()
      civetTsx := program.getSourceFiles().find (sf) => sf.fileName.endsWith 'main.civet.tsx'
      assert civetTsx, "program should include the synthetic .civet.tsx sibling"

      diagnostics := builder.getSemanticDiagnostics civetTsx
      assert.equal diagnostics.length, 0, `expected no diagnostics, got: ${diagnostics.map(.messageText).join(' | ')}`

      meta := getMeta civetPath
      assert meta?.sourcemapLines, "getMeta should return sourcemap lines for the .civet source"
    finally
      rmSync tmpDir, { recursive: true, force: true }

  it "captures parse errors as fatal FileMeta (sourceFile undefined)", ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-incremental-parse-'
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'),
        '{"compilerOptions":{"target":"es2020","strict":true,"jsx":"preserve"},"include":["**/*.civet"]}'
      civetPath := path.join tmpDir, 'broken.civet'
      // Malformed civet that fails to parse (unbalanced quote).
      writeFileSync civetPath, "x := 'unterminated\n"

      { getMeta } := makeIncrementalTypecheckProgram tmpDir, {
        plugins: [makeCivetPlugin()]
      }
      // Force snapshot creation by reaching for getMeta — the host's
      // getSourceFile runs the transpiler, the catch arm fires, and
      // FileMeta.fatal=true is recorded.
      meta := getMeta civetPath
      // (getSourceFile was driven by ts when constructing the program)
      assert meta?.fatal or (meta?.parseErrors and meta.parseErrors.length > 0),
        `expected fatal/parseErrors meta for broken.civet, got: ${JSON.stringify meta}`
    finally
      rmSync tmpDir, { recursive: true, force: true }

  it "surfaces type errors from civet sources via per-file diagnostics", ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-incremental-errors-'
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'),
        '{"compilerOptions":{"target":"es2020","strict":true,"jsx":"preserve"},"include":["**/*.civet"]}'
      civetPath := path.join tmpDir, 'bad.civet'
      writeFileSync civetPath, "x: number := 'wrong type'\n"

      { builder } := makeIncrementalTypecheckProgram tmpDir, {
        plugins: [makeCivetPlugin()]
      }
      program := builder.getProgram()
      target := program.getSourceFiles().find (sf) => sf.fileName.endsWith 'bad.civet.tsx'
      assert target
      diagnostics := builder.getSemanticDiagnostics target
      assert diagnostics.length > 0,
        "expected at least one type error from `x: number := 'wrong type'`"
    finally
      rmSync tmpDir, { recursive: true, force: true }

  it "resolves cross-file civet imports via resolveModuleNameLiterals", ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-incremental-imports-'
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'),
        '{"compilerOptions":{"target":"es2020","strict":true,"jsx":"preserve"},"include":["**/*.civet"]}'
      writeFileSync path.join(tmpDir, 'dep.civet'), "export answer := 42\n"
      consumerPath := path.join tmpDir, 'consumer.civet'
      writeFileSync consumerPath, "{ answer } from ./dep.civet\nconsole.log answer\n"

      { builder } := makeIncrementalTypecheckProgram tmpDir, {
        plugins: [makeCivetPlugin()]
      }
      program := builder.getProgram()
      // The dep.civet sibling must be loaded for cross-file types to work
      depTsx := program.getSourceFiles().find (sf) => sf.fileName.endsWith 'dep.civet.tsx'
      assert depTsx, "expected dep.civet.tsx to be in the program (resolveModuleNameLiterals)"

      consumer := program.getSourceFiles().find (sf) => sf.fileName.endsWith 'consumer.civet.tsx'
      assert consumer
      diagnostics := builder.getSemanticDiagnostics consumer
      assert.equal diagnostics.length, 0,
        `expected no diagnostics on the consumer, got: ${diagnostics.map(.messageText).join(' | ')}`
    finally
      rmSync tmpDir, { recursive: true, force: true }

  it "fileExists override redirects synthetic .civet.tsx to the on-disk .civet source", ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-incremental-fileexists-'
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'),
        '{"compilerOptions":{"target":"es2020","strict":true,"jsx":"preserve"},"include":["**/*.civet"]}'
      civetPath := path.join tmpDir, 'main.civet'
      writeFileSync civetPath, "x: number := 1\n"

      { host } := makeIncrementalTypecheckProgram tmpDir, {
        plugins: [makeCivetPlugin()]
      }
      // Synthetic .civet.tsx — no such file on disk, but the override claims
      // it exists by redirecting to the .civet source check.  Without this,
      // resolveModuleNameLiterals's outputs would fail validation.
      assert.equal host.fileExists(civetPath + '.tsx'), true
      // .civet.tsx for a path with NO underlying .civet source
      assert.equal host.fileExists(path.join(tmpDir, 'missing.civet.tsx')), false
      // 2-extension path that doesn't match a transpiler target — passes
      // through to baseHost.
      assert.equal host.fileExists(path.join(tmpDir, 'something.foo.bar')), false
      // Single-extension path — `if exts` is false, straight to baseHost.
      assert.equal host.fileExists(path.join(tmpDir, 'tsconfig.json')), true
      assert.equal host.fileExists(path.join(tmpDir, 'no-such-file.json')), false
    finally
      rmSync tmpDir, { recursive: true, force: true }

  it "falls back to ts.resolveModuleName for non-civet imports", ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-incremental-resolve-'
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'),
        '{"compilerOptions":{"target":"es2020","strict":true,"jsx":"preserve","allowJs":true,"module":"esnext","moduleResolution":"bundler"},"include":["**/*.civet","**/*.ts"]}'
      // A .ts sibling — the import name doesn't end in `.civet`/`.hera`,
      // so resolveModuleNameLiterals's loop falls through to
      // ts.resolveModuleName which finds the .ts file via the standard resolver.
      writeFileSync path.join(tmpDir, 'sibling.ts'),
        'export const greeting: string = "hello";\n'
      civetPath := path.join tmpDir, 'main.civet'
      writeFileSync civetPath, '{ greeting } from ./sibling\nconsole.log greeting\n'

      { builder } := makeIncrementalTypecheckProgram tmpDir, {
        plugins: [makeCivetPlugin()]
      }
      program := builder.getProgram()
      consumer := program.getSourceFiles().find (sf) => sf.fileName.endsWith 'main.civet.tsx'
      assert consumer
      diagnostics := builder.getSemanticDiagnostics consumer
      assert.equal diagnostics.length, 0,
        `expected the .ts import to resolve cleanly, got: ${diagnostics.map(.messageText).join(' | ')}`
      // Confirm the .ts file made it into the program (resolveModuleName fallback worked)
      assert program.getSourceFiles().some((sf) => sf.fileName.endsWith 'sibling.ts'),
        "expected sibling.ts in program after resolveModuleName fallback"
    finally
      rmSync tmpDir, { recursive: true, force: true }

  it "writes tsbuildinfo and skips affected work on a warm rerun", ->
    tmpDir := mkdtempSync path.join tmpdir(), 'civet-incremental-warm-'
    try
      writeFileSync path.join(tmpDir, 'tsconfig.json'),
        '{"compilerOptions":{"target":"es2020","strict":true,"jsx":"preserve"},"include":["**/*.civet"]}'
      writeFileSync path.join(tmpDir, 'main.civet'), "x: number := 5\nconsole.log x\n"
      tsbi := path.join tmpDir, '.tsbuildinfo'

      runOnce := =>
        { builder } := makeIncrementalTypecheckProgram tmpDir, {
          plugins: [makeCivetPlugin()]
          extraCompilerOptions: { incremental: true, tsBuildInfoFile: tsbi, noEmit: false }
        }
        // Drain affected so the per-file cache is populated, then emit.
        affected .= 0
        loop
          r := builder.getSemanticDiagnosticsOfNextAffectedFile()
          break unless r
          affected++
        builder.emit undefined, ((fn, data) =>
          writeFileSync fn, data if fn is tsbi
        ), undefined, false
        affected

      // First run: every file is "affected" (no prior state).
      firstAffected := runOnce()
      assert firstAffected > 0, "first run should re-check at least one file"

      // Second run: tsbuildinfo present, signatures match, nothing to redo.
      secondAffected := runOnce()
      assert.equal secondAffected, 0,
        `warm rerun should skip every file; got ${secondAffected} affected`
    finally
      rmSync tmpDir, { recursive: true, force: true }
