// Shared defaults for browser-hosted LSP projects without a user tsconfig.

export browserDefaultTsConfig :=
  compilerOptions:
    target: 'ES2020'
    module: 'ESNext'
    moduleResolution: 'Bundler'
    strict: true
    jsx: 'preserve'
    noEmit: true
    lib: ['ES2020']
    allowJs: true
    checkJs: true
  include: ['**/*']
