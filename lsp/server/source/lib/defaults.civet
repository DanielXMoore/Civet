// Shared defaults for browser-hosted LSP projects without a user tsconfig.

export browserDefaultTsConfig :=
  compilerOptions:
    target: 'ES2025'
    module: 'ESNext'
    moduleResolution: 'Bundler'
    strict: true
    jsx: 'preserve'
    noEmit: true
    lib: ['ES2025']
    allowJs: true
    checkJs: true
  include: ['**/*']
