// Node entrypoint. Creates the Node LSP connection, then starts the shared
// server core with the Node implementations of platform-specific services.
{
  createConnection
  ProposedFeatures
} from vscode-languageserver/node
{ startServer } from ./server.civet
TSService from ./lib/typescript-service.civet
ts from typescript

startServer createConnection(ProposedFeatures.all), {
  TSService
  tsSys: ts.sys
}
