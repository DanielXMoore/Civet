{
  "name": "@danielx/civet-language-server",
  "description": "Civet Language Server (standalone, editor-agnostic)",
  "version": "0.3.34",
  "repository": {
    "type": "git",
    "url": "https://github.com/DanielXMoore/civet.git"
  },
  "files": [
    "bin",
    "dist",
    "types"
  ],
  "main": "./dist/node.js",
  "browser": "./dist/browser.js",
  "exports": {
    ".": {
      "browser": "./dist/browser.js",
      "node": "./dist/node.js",
      "require": "./dist/node.js",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./node": {
      "require": "./dist/node.js",
      "import": "./dist/node.js"
    },
    "./browser": "./dist/browser.js",
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "bin": {
    "civet-lsp": "./bin/civet-lsp.js"
  },
  "scripts": {
    "prepublishOnly": "pnpm build",
    "build": "bash ./build/build.sh",
    "build-dev": "bash ./build/build.sh development",
    "test": "pnpm build && mocha --config .mocharc.json",
    "test:coverage": "pnpm build && c8 mocha --config .mocharc.json --no-parallel"
  },
  "c8": {
    "all": true,
    "allow-external": true,
    "exclude-after-remap": true,
    "reporter": [
      "lcov",
      "json"
    ],
    "extension": [
      ".civet",
      ".ts"
    ],
    "include": [
      "**/lsp/server/source/**",
      "**/source/ts-service/**"
    ],
    "exclude": [
      "**/node_modules/**",
      "**/test/**",
      "**/lsp/server/source/browser.civet"
    ]
  },
  "dependencies": {
    "typescript": "^6.0.2",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@danielx/civet": "workspace:*",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "@typescript/vfs": "^1.6.4",
    "c8": "^11.0.0",
    "esbuild": "^0.27.7",
    "mocha": "^11.7.5",
    "source-map-support": "^0.5.21",
    "web-worker": "^1.5.0"
  }
}
