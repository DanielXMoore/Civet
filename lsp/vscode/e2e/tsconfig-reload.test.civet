* as vscode from vscode
assert from assert
{ getDocUri, getDocPath, activate, poll } from ./helper.civet

suite 'TSConfig Reload', =>
  tsConfigPath := getDocPath 'tsconfig.json'
  tsConfigUri := vscode.Uri.file tsConfigPath
  encoder := new TextEncoder()
  decoder := new TextDecoder()
  originalContent .= ''

  setup =>
    bytes := await vscode.workspace.fs.readFile tsConfigUri
    originalContent = decoder.decode bytes

  teardown =>
    await vscode.workspace.fs.writeFile tsConfigUri, encoder.encode originalContent

  test 'Re-sends diagnostics and applies new tsconfig settings after change', ->
    @timeout 30000
    // unused-local.civet has `x := 42`.  TS's IDE flow always emits a
    // Hint-severity TS6133 marker for `x` regardless of tsconfig; only an
    // Error-severity diagnostic indicates that the post-reload tsconfig
    // (with noUnusedLocals) is in effect.
    docUri := getDocUri 'unused-local.civet'
    await activate docUri

    isError := (d: vscode.Diagnostic) =>
      d.severity is vscode.DiagnosticSeverity.Error
    isErrorAboutX := (d: vscode.Diagnostic) =>
      isError(d) and d.message.includes 'x'
    formatDiags := (ds: readonly vscode.Diagnostic[]) =>
      if ds.length is 0 then '[]'
      else ds.map((d) => `sev=${d.severity}: ${d.message}`).join ' | '

    // Wait until the initial diagnostic pass has settled (no Error-severity
    // entries yet — Hint-only is the expected pre-reload state).
    await poll(
      () => Promise.resolve vscode.languages.getDiagnostics docUri
      (ds) => not ds.some isError
      5000
      250
      formatDiags
    )

    // Modify tsconfig to enable noUnusedLocals.
    parsed := JSON.parse originalContent
    parsed.compilerOptions.noUnusedLocals = true
    await vscode.workspace.fs.writeFile(
      tsConfigUri
      encoder.encode JSON.stringify(parsed, null, 2)
    )

    // Poll for the substantive condition: an Error-severity diagnostic
    // about `x`.  Polling tolerates stale Hint-only publishes, file-watcher
    // latency, and a transient OLD-service publish overwriting NEW.
    diagnostics := await poll(
      () => Promise.resolve vscode.languages.getDiagnostics docUri
      (ds) => ds.some isErrorAboutX
      10000
      250
      formatDiags
    )

    assert diagnostics.some(isErrorAboutX),
      `Expected an Error diagnostic about 'x'; got: ${formatDiags diagnostics}`
