* as vscode from vscode
* as fs from 'node:fs'
assert from assert
{ getDocUri, getDocPath, activate, onNextDiagnostics, poll } from ./helper.civet

suite 'TSConfig Reload', =>
  tsConfigPath := getDocPath 'tsconfig.json'
  originalContent .= ''

  setup =>
    originalContent = fs.readFileSync tsConfigPath, 'utf8'

  teardown =>
    fs.writeFileSync tsConfigPath, originalContent

  test 'Re-sends diagnostics and applies new tsconfig settings after change', async =>
    // unused-local.civet has `x := 42` — unused local.
    // With the default tsconfig (no noUnusedLocals) there should be no errors.
    docUri := getDocUri 'unused-local.civet'
    await activate docUri

    // Wait until the initial diagnostic pass has run (no errors).
    // TS's IDE flow always emits an Information-level "unused"
    // marker for `x := 42` (TS6133, severity Hint) regardless of
    // noUnusedLocals — only `Error`-severity entries indicate that
    // the post-modification state has actually arrived.
    await poll(
      () => Promise.resolve vscode.languages.getDiagnostics docUri
      (d) => d.every (e) => e.severity is not vscode.DiagnosticSeverity.Error
      20000
    )

    // === Debug observability ================================================
    // Track every diagnostic event the LSP publishes (any URI), and every
    // tsconfig.json change VS Code sees, so a timeout reveals which link
    // is broken: VS Code never saw the change | server never republished |
    // server republished but not for unused-local.civet.
    diagEvents: { uri: string, count: number, severities: number[] }[] := []
    fsEvents: string[] := []
    diagSub := vscode.languages.onDidChangeDiagnostics (e) =>
      for u of e.uris
        ds := vscode.languages.getDiagnostics u
        diagEvents.push {
          uri: u.fsPath
          count: ds.length
          severities: ds.map(.severity)
        }
    fsWatcher := vscode.workspace.createFileSystemWatcher '**/tsconfig.json'
    fsWatcher.onDidChange (u) => fsEvents.push `change ${u.fsPath}`
    fsWatcher.onDidCreate (u) => fsEvents.push `create ${u.fsPath}`
    // =========================================================================

    // Subscribe to the next diagnostics event BEFORE modifying tsconfig
    // so we cannot miss it.
    diagPromise := onNextDiagnostics docUri, 30000

    // Give VS Code's tsconfig.json watcher time to attach before flipping
    // content — Windows' ReadDirectoryChangesW takes longer to bind than
    // Linux's inotify, and the package.json watcher test in
    // extension.test.civet uses the same pattern.
    await new Promise<void> (r) => setTimeout r, 1500

    // Modify tsconfig to enable noUnusedLocals — this should surface an
    // error in unused-local.civet once the server reloads the TSService.
    // Route the write through `vscode.workspace.fs.writeFile` so VS Code's
    // own watcher fires reliably (raw `fs.writeFileSync` doesn't always
    // propagate to ReadDirectoryChangesW in time on Windows).
    parsed := JSON.parse originalContent
    parsed.compilerOptions.noUnusedLocals = true
    encoder := new TextEncoder()
    await vscode.workspace.fs.writeFile(
      vscode.Uri.file(tsConfigPath)
      encoder.encode JSON.stringify(parsed, null, 2)
    )

    // The server debounces 300 ms, rebuilds TSService, then re-sends
    // diagnostics for all open documents.  Wait for that event.
    let diagnostics: vscode.Diagnostic[]
    try
      diagnostics = await diagPromise
    catch e
      console.error `=== tsconfig-reload debug ===`
      console.error `fsWatcher events (${fsEvents.length}): ${fsEvents.join(' | ')}`
      console.error `diagnostic events seen (${diagEvents.length}):`
      for d of diagEvents
        console.error `  ${d.uri} count=${d.count} severities=[${d.severities.join(',')}]`
      diagSub.dispose()
      fsWatcher.dispose()
      throw e
    diagSub.dispose()
    fsWatcher.dispose()

    assert diagnostics.length >= 1,
      `Expected at least one diagnostic after enabling noUnusedLocals, got ${diagnostics.length}`
    assert diagnostics.some((d) => d.message.includes 'x'),
      `Expected a diagnostic about 'x', got: ${diagnostics.map((d) => d.message).join(', ')}`
