{ commands, Position, type Location, type LocationLink, Uri } from vscode
assert from assert
{ getDocUri, activate, poll } from ./helper.civet

// Extract the target URI from a definition result (Location or LocationLink)
getDefUri := (d: Location | LocationLink): Uri =>
  (d as LocationLink).targetUri ?? (d as Location).uri

suite 'Go To Definition', =>
  test 'Jumps to definition in another Civet file', async =>
    // consumer.civet imports `greet` from valid.civet
    // Position of `greet` on line 0 of consumer.civet
    docUri := getDocUri('consumer.civet')
    await activate(docUri)

    position := new Position(0, 2)
    defs := await poll(
      () => commands.executeCommand(
        'vscode.executeDefinitionProvider',
        docUri,
        position
      ) as Promise<(Location | LocationLink)[]>
      (d) => d?.length > 0
    )

    assert defs?.length > 0, 'Expected at least one definition'
    defUri := getDefUri(defs[0])
    assert defUri.fsPath.endsWith('valid.civet'), `Expected definition in valid.civet, got: ${defUri.fsPath}`

  test 'Jumps to definition from a .ts file', async =>
    // consumer.ts imports `greet` from valid.ts
    docUri := getDocUri('consumer.ts')
    await activate(docUri)

    // Position of `greet` on line 1 of consumer.ts (after `greet(`)
    position := new Position(1, 1)
    defs := await poll(
      () => commands.executeCommand(
        'vscode.executeDefinitionProvider',
        docUri,
        position
      ) as Promise<(Location | LocationLink)[]>
      (d) => d?.some (def) => !getDefUri(def).fsPath.endsWith('consumer.ts')
    )

    assert defs?.length > 0, 'Expected at least one definition from .ts file'
    // Find the definition that points to valid.ts (not the import in consumer.ts)
    def := defs.find (d) => !getDefUri(d).fsPath.endsWith('consumer.ts')
    assert def, `Expected definition outside consumer.ts, got: ${defs.map((d) => getDefUri(d).fsPath).join(', ')}`
    defUri := getDefUri(def)
    assert defUri.fsPath.endsWith('valid.ts') or defUri.fsPath.endsWith('valid.js'), `Expected definition in valid.ts, got: ${defUri.fsPath}`
