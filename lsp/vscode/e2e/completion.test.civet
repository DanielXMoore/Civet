{ commands, Position } from vscode
type { CompletionList, CompletionItem } from vscode
assert from assert
{ getDocUri, activate, poll } from ./helper.civet

getLabel := (i: CompletionItem) =>
  i.label <? 'string' ? i.label : i.label.label

suite 'Completion', =>
  test 'Returns completions for console.', =>
    docUri := getDocUri('console.civet')
    await activate(docUri)

    // Poll until TypeScript has loaded project types and returns member completions.
    // On first request the server may return scope-level completions before the
    // full type graph (lib.dom / @types/node) is ready.
    completions := await poll(
      () => commands.executeCommand(
        'vscode.executeCompletionItemProvider'
        docUri
        new Position(0, 8)
      ) as Promise<CompletionList>
      (list) => list?.items.some((i) => getLabel(i) === 'log')
    )

    labels := completions.items.map(getLabel)
    assert labels.includes('log'), `Expected 'log' in console completions, got: ${labels.join(', ')}`

  test 'Resolves completion item details', =>
    docUri := getDocUri('console.civet')
    await activate(docUri)

    // Pass itemResolveCount=1 to trigger onCompletionResolve for the first item
    completions := await poll(
      () => commands.executeCommand(
        'vscode.executeCompletionItemProvider'
        docUri
        new Position(0, 8)
        undefined
        1
      ) as Promise<CompletionList>
      (list) => list?.items.some((i) => getLabel(i) === 'log')
    )

    assert completions.items.length > 0, 'Expected resolved completion items'

  test 'Returns completions for a .ts file', =>
    docUri := getDocUri('consumer.ts')
    await activate(docUri)

    // `greet` call on line 1, col 6 — after `greet(`
    completions := await poll(
      () => commands.executeCommand(
        'vscode.executeCompletionItemProvider'
        docUri
        new Position(1, 6)
      ) as Promise<CompletionList>
      (list) => list?.items.length > 0
    )

    assert completions.items.length > 0, 'Expected completions in .ts file'

  test 'Returns completions for an empty .ts file', =>
    docUri := getDocUri('empty.ts')
    await activate(docUri)

    completions := await commands.executeCommand(
      'vscode.executeCompletionItemProvider'
      docUri
      new Position(0, 0)
    ) as CompletionList

    // Empty file should still get global completions or empty list
    assert completions, 'Expected a completion list (possibly empty)'
