* as vscode from vscode
assert from assert
{ getDocUri, activate, poll } from ./helper.civet

suite 'Rename', =>
  test 'Renames a function in a Civet file', async =>
    docUri := getDocUri('valid.civet')
    await activate(docUri)

    // `farewell` is on line 6 (0-indexed), col 16
    position := new vscode.Position(6, 16)

    edit := await poll(
      () => vscode.commands.executeCommand(
        'vscode.executeDocumentRenameProvider'
        docUri
        position
        'goodbye'
      ) as Promise<vscode.WorkspaceEdit | undefined>
      (e) => !!e and e.size > 0
    )

    assert edit, 'Expected a workspace edit from rename'
    assert edit.size > 0, 'Expected at least one file in the edit'

    entries := edit.entries()
    allEdits := entries.flatMap ([, edits]) => edits
    assert allEdits.some((e) => e.newText is 'goodbye'),
      'Expected rename to produce edit with new name'

  test 'Renames a symbol in a .ts file', async =>
    docUri := getDocUri('valid.ts')
    await activate(docUri)

    // `ANSWER` is on line 5 (0-indexed), col 13
    position := new vscode.Position(5, 13)

    edit := await poll(
      () => vscode.commands.executeCommand(
        'vscode.executeDocumentRenameProvider'
        docUri
        position
        'RESULT'
      ) as Promise<vscode.WorkspaceEdit | undefined>
      (e) => !!e and e.size > 0
    )

    assert edit, 'Expected a workspace edit from .ts rename'
    entries := edit.entries()
    allEdits := entries.flatMap ([, edits]) => edits
    assert allEdits.some((e) => e.newText is 'RESULT'),
      'Expected rename to produce edit with new name'

  test 'Renames across files with multiple edits per file', async =>
    // consumer.civet imports and calls `greet` — renaming `greet`
    // should produce 2 edits in consumer.civet (import + usage)
    docUri := getDocUri('consumer.civet')
    await activate(docUri)

    // `greet` in `{ greet } from ./valid.civet` — line 0, col 2
    position := new vscode.Position(0, 2)

    edit := await poll(
      () => vscode.commands.executeCommand(
        'vscode.executeDocumentRenameProvider'
        docUri
        position
        'hello'
      ) as Promise<vscode.WorkspaceEdit | undefined>
      (e) => !!e and e.size > 1
    )

    assert edit, 'Expected a workspace edit from cross-file rename'
    assert edit.size > 1, `Expected edits in multiple files, got ${edit.size}`
