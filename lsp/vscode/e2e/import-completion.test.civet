{ commands, Position } from vscode
type { CompletionList, CompletionItem } from vscode
assert from assert
{ getDocUri, activate, poll } from ./helper.civet

getLabel := (i: CompletionItem) =>
  i.label <? 'string' ? i.label : i.label.label

suite 'Import Path Completion', =>
  test 'Returns path completions for import from ./', =>
    docUri := getDocUri('import-completion.civet')
    await activate(docUri)

    // Cursor at end of `x from "./` — position after the last character
    completions := await poll(
      () => commands.executeCommand(
        'vscode.executeCompletionItemProvider'
        docUri
        new Position(0, 10)
      ) as Promise<CompletionList>
      (list) => list?.items.length > 0
    )

    labels := completions.items.map(getLabel)
    assert labels.length > 0,
      `Expected path completions for relative import, got: ${labels.join(', ')}`

  test 'Returns path alias completions for @lib/', =>
    docUri := getDocUri('alias-import.civet')
    await activate(docUri)

    // Cursor at end of `x from "@lib/` — position after the last character
    completions := await poll(
      () => commands.executeCommand(
        'vscode.executeCompletionItemProvider'
        docUri
        new Position(0, 14)
      ) as Promise<CompletionList>
      (list) => list?.items.some((i) => getLabel(i).includes('helpers'))
    )

    labels := completions.items.map(getLabel)
    assert labels.some((l) => l.includes('helpers')),
      `Expected alias completions to include 'helpers', got: ${labels.join(', ')}`

  test 'Returns import path completions in a .ts file', =>
    docUri := getDocUri('ts-import.ts')
    await activate(docUri)

    // Cursor at end of `import { } from "./` — after the `/`
    completions := await poll(
      () => commands.executeCommand(
        'vscode.executeCompletionItemProvider'
        docUri
        new Position(0, 20)
      ) as Promise<CompletionList>
      (list) => list?.items.length > 0
    )

    labels := completions.items.map(getLabel)
    assert labels.length > 0,
      `Expected import path completions in .ts file, got: ${labels.join(', ')}`

  test 'Returns completions for exact path alias @helpers/', =>
    docUri := getDocUri('exact-alias-import.civet')
    await activate(docUri)

    // Cursor at end of `x from "@helpers/`
    completions := await poll(
      () => commands.executeCommand(
        'vscode.executeCompletionItemProvider'
        docUri
        new Position(0, 17)
      ) as Promise<CompletionList>
      (list) => list?.items.length > 0
    )

    labels := completions.items.map(getLabel)
    assert labels.length > 0,
      `Expected completions for exact alias, got: ${labels.join(', ')}`
