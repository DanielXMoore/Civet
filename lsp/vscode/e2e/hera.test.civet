{ commands, Position, type Location, type LocationLink, Uri, type Range } from vscode
assert from assert
{ getDocUri, activate, poll } from ./helper.civet

getDefUri := (d: Location | LocationLink): Uri =>
  (d as LocationLink).targetUri ?? (d as Location).uri

getDefRange := (d: Location | LocationLink): Range =>
  (d as LocationLink).targetRange ?? (d as Location).range

suite 'Hera grammar-level LSP', =>
  test 'Go to definition jumps from a rule reference to its declaration', async =>
    docUri := getDocUri('grammar.hera')
    await activate(docUri)

    // `Greeting` reference inside Start's body (line 1, col 2).
    position := new Position(1, 2)
    defs := await poll(
      () => commands.executeCommand(
        'vscode.executeDefinitionProvider'
        docUri
        position
      ) as Promise<(Location | LocationLink)[]>
      (d) => d?.length > 0
    )

    assert defs?.length > 0, 'Expected a definition for the Greeting rule reference'
    defUri := getDefUri(defs[0])
    assert defUri.fsPath.endsWith('grammar.hera'),
      `Expected definition in grammar.hera, got: ${defUri.fsPath}`
    // Greeting is declared on line 3.
    assert.strictEqual getDefRange(defs[0]).start.line, 3,
      `Expected the Greeting declaration on line 3`
