{
  "fileTypes": [],
  "injectionSelector": "L:(meta.script.svelte) (meta.lang.civet) - (meta source)",
  "patterns": [
    {
      "begin": "(?<=>)(?=[^\\n]+</(script)[\\s>])",
      "end": "(?=</(script)[\\s>])",
      "name": "meta.embedded.block.svelte",
      "contentName": "source.civet",
      "patterns": [
        {
          "include": "source.civet"
        }
      ]
    },
    {
      "begin": "(?<=>)(?!</)",
      "while": "^(?!\\s*</(script)[\\s>])",
      "name": "meta.embedded.block.svelte",
      "contentName": "source.civet",
      "patterns": [
        {
          "include": "source.civet"
        }
      ]
    }
  ],
  "scopeName": "svelte.civet.injection"
}
