{ build } from esbuild
civetPlugin from @danielx/civet/esbuild

build({
  entryPoints: [
    'test/e2e/suite/index.ts'
    'test/e2e/suite/extension.test.ts'
  ]
  outdir: 'out/test/e2e/suite'
  format: "cjs"
  bundle: true
  external: ['vscode', 'mocha']
  platform: 'node'
  plugins: [civetPlugin ts: 'civet']
  tsconfig: "./tsconfig.json"
}).catch ->
  process.exit 1
