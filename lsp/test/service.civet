import TSService from "../source/lib/typescript-service.mjs"
import { pathToFileURL } from "url"
import { TextDocument } from "vscode-languageserver-textdocument"
import fs from "fs"
import os from "os"
import path from "path"

{ forwardMap } from ../source/lib/util.mjs

assert from assert

loadFile := async (service: Awaited<ReturnType<typeof TSService>>, path: string) ->
  document := TextDocument.create(pathToFileURL(path).href, "civet", 0, fs.readFileSync(path, "utf8"))
  service.host.addOrUpdateDocument(document)

describe "ts service", ->
  @timeout 5000
  it "should launch ts service", async ->
    service := await TSService(pathToFileURL("./integration/project-test/").href)
    await service.loadPlugins()

    filePath := "./integration/project-test/a.civet"
    await loadFile(service, filePath)

    diagnostics := service.getSemanticDiagnostics(filePath + ".tsx")

    console.log diagnostics
    // console.log service.host.getScriptFileNames()

    assert.equal diagnostics.length, 0

    {transpiledDoc, sourcemapLines} := service.host.getMeta(filePath)!

    position := transpiledDoc!.offsetAt forwardMap(sourcemapLines, {
      line: 0
      character: 0
    })
    info := service.getQuickInfoAtPosition(filePath + ".tsx", position)

    assert info

  it "should give member completions for @ shorthand", async ->
    // This test verifies the fix for issue #825:
    // When user types @ in a class method, the server should give member completions,
    // not completions that would result in @this.member when accepted.
    service := await TSService(pathToFileURL("./integration/project-test/").href)
    await service.loadPlugins()

    // Create a temp file with a class that has a member `bar`
    src := "class Foo\n  bar := 42\n  foo()\n    @"
    tmpDir := os.tmpdir()
    filePath := path.join(tmpDir, "test_at_completions.civet")
    document := TextDocument.create(pathToFileURL(filePath).href, "civet", 0, src)
    service.host.addOrUpdateDocument(document)

    meta := service.host.getMeta(filePath)
    assert meta, "should have meta for the file"

    {transpiledDoc, sourcemapLines} := meta
    assert transpiledDoc, "should have transpiled doc"
    assert sourcemapLines, "should have sourcemap lines"

    transpiledText := transpiledDoc.getText()
    transpiledPath := filePath + ".tsx"

    // The transpiled code for `@` alone contains `this` (without dot)
    assert.ok transpiledText.includes("this"), "transpiled code should contain 'this'"

    // Find the position after `this` in the transpiled code
    // (This simulates what the server does after the @ cursor fix)
    thisIdx := transpiledText.indexOf("this")
    assert.ok thisIdx >= 0, "should find 'this' in transpiled code"
    afterThis := thisIdx + 4  // position right after `this`

    // With the fix: position after `this` with `.` trigger gives member completions
    completions := service.getCompletionsAtPosition(
      transpiledPath,
      afterThis,
      {
        triggerCharacter: "." as any,
        includeCompletionsWithInsertText: true,
        useLabelDetailsInCompletionEntries: true,
      }
    )

    assert completions, "should get completions after `this`"
    names := completions.entries.map (e) => e.name
    assert.ok names.includes("bar"),
      `completions should include 'bar' member (got: ${names.slice(0,5).join(', ')})`

    // TypeScript may return insertText starting with `this.` for "ThisProperty" completions
    // (source: "ThisProperty/"). The server's convertCompletions strips the `this.` prefix
    // for Civet files so that accepting a completion on `@` gives `@member` not `@this.member`.
    for entry of completions.entries
      if entry.name is "bar"
        rawInsertText := entry.insertText ?? entry.name
        // Simulate what convertCompletions does: strip `this.` for ThisProperty completions
        processedInsertText := rawInsertText.startsWith("this.") and entry.source is "ThisProperty/"
          ? rawInsertText.slice("this.".length)
          : rawInsertText
        assert.equal processedInsertText, "bar",
          `bar completion should produce 'bar' after server processing (raw: '${rawInsertText}')`
