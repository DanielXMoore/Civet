hasTypeScriptEslint :=
  try
    await import "typescript-eslint"
    true
  catch
    false

defaultConfig :=
  if hasTypeScriptEslint
    import civetPlugin from ./ts.js
    [
      ...civetPlugin.configs.jsRecommended
      ...civetPlugin.configs.strict
      ...civetPlugin.configs.stylistic
    ]
  else
    import civetPlugin from ./index.js
    civetPlugin.configs.recommended

export default defaultConfig
