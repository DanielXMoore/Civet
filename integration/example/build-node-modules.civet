// This file is used in test/integration.civet to test sourcemap source for node_modules
esbuild from esbuild

civetPlugin from ../../dist/unplugin/esbuild.mjs

esbuild.build {
  +sourcemap
  entryPoints: ['source/uses-pkg.civet'],
  outdir: 'dist',
  bundle: true,
  plugins: [
    civetPlugin({})
  ]
}
