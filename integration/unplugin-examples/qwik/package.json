{
  "name": "civet-example-qwik",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.civet": "civet --emit-declaration $(find src -name '*.civet')",
    "build.types": "npm run build.civet && tsc --incremental --noEmit",
    "dev": "vite --mode ssr",
    "preview": "qwik build preview && vite preview",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@danielx/civet": "workspace:*",
    "typescript": "5.4.5",
    "undici": "*",
    "vite": "7.3.1"
  }
}
