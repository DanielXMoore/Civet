type {
  ArrowFunction
  ASTLeaf
  ASTNode
  ASTNodeObject
  AssignmentExpression
  Call
  ParenthesizedExpression
  ThrowStatement
} from ./types.civet
{ gatherRecursiveAll } from ./traversal.civet
{
  addParentPointers
  checkValidLHS
  clone
  isASTNodeObject
  isToken
  makeLeftHandSideExpression
  makeNode
  removeHoistDecs
  skipIfOnlyWS
  updateParentPointers
} from ./util.civet
{
  makeRef
  needsRef
} from ./ref.civet

{ blockContainingStatement } from ./block.civet
{ processUnaryExpression } from ./unary.civet

type ExprWithComments
  expr: ASTNode!
  leadingComment: ASTNode
  trailingComment: ASTNode

function constructInvocation(fn: ExprWithComments, arg: ASTNode!)
  // Unwrap ampersand blocks
  expr: NonNullable<ASTNode> .= fn.expr
  while isASTNodeObject(expr) and expr.type is "ParenthesizedExpression"
    expr = (expr as ParenthesizedExpression).expression
  if isASTNodeObject(expr) and expr.type is "ArrowFunction" and expr.ampersandBlock
    arrow := expr as ArrowFunction & { ref: ASTNodeObject, body: ASTNode }
    { ref, body } := arrow

    // We mutate the ref in place to a synthetic "PipedExpression" — not a
    // declared AST node type, but the generator only looks at .children
    // for non-leaf nodes, so the renamed type tag is harmless.
    asMut := ref as unknown as { type: string, children: ASTNode[] }
    asMut.type = "PipedExpression"
    asMut.children = [makeLeftHandSideExpression(arg)]
    updateParentPointers ref

    return makeNode {
      type: "UnwrappedExpression"
      expression: body
      children: [skipIfOnlyWS(fn.leadingComment), body, skipIfOnlyWS(fn.trailingComment)]
    }

  expr = fn.expr
  lhs: ASTNodeObject .= expr as ASTNodeObject
  // NewExpressions get handled specially later
  unless lhs.type is "NewExpression"
    lhs = makeLeftHandSideExpression(lhs)! as ASTNodeObject

  // Attach comments — by this point lhs is a NewExpression or a wrapped LHS,
  // both of which carry .children.
  lhsChildren := (lhs as ASTNodeObject & { children: ASTNode[] }).children
  comment .= skipIfOnlyWS(fn.trailingComment)
  if comment then lhsChildren.push comment
  comment = skipIfOnlyWS(fn.leadingComment)
  if comment then lhsChildren.splice(1, 0, comment)

  args := [arg]
  call: Call := {
    type: "Call"
    args
    children: ["(", args, ")"]
  }
  // Turn `|> new Foo` into `new Foo(arg)` by adding to existing CallExpression
  if lhs.type is "NewExpression"
    { expression } .= lhs
    expression = {
      type: "CallExpression"
      children: [ expression, call ]
    }
    {
      ...lhs
      expression
      children: lhs.children.map & is lhs.expression ? expression : &
    }
  else
    {
      type: "CallExpression"
      children: [lhs, call]
    }

function constructPipeStep(fn: ExprWithComments, arg: ASTNode!, returning: ASTNode??): [ASTNode, ASTNode??]
  returning = null unless returning
  children: ASTNode[] .= [[fn.leadingComment, fn.expr, fn.trailingComment].map(skipIfOnlyWS), " ", arg]

  // Handle special non-function cases.  fn.expr is the bare keyword token
  // for await/yield/throw/return.  Guard with isToken so .token narrows.
  if isToken fn.expr
    switch fn.expr.token
      when "await"
        children = processUnaryExpression([fn.expr], arg, undefined) as ASTNode[]
        continue switch  // fall through to "yield" arm
      when "yield"
        return [children, returning] as! [ASTNode, ASTNode??]
      when "throw"
        statement: ThrowStatement := { type: "ThrowStatement", children }
        return [
          {
            type: "StatementExpression"
            statement
            children: [statement]
          } as ASTNode
          null
        ]
      when "return"
        // Return ignores ||> returning argument
        return [
          {
            type: "ReturnStatement"
            children
          } as ASTNode
          null
        ]

  return [
    constructInvocation(fn, arg) as ASTNode
    returning
  ]

// head: expr
// body: [ws, pipe, ws, expr][]

type PipeArg = ASTNode! & { type?: string, children?: ASTNode[], $loc?: { pos: number, length: number } }

function processPipelineExpressions(statements: ASTNode): void
  for each pipelineExp of gatherRecursiveAll statements, .type is "PipelineExpression"
    // Pipeline children mutate during processing — alias to a wider shape
    // so the assignments below typecheck without per-line casts.
    s := pipelineExp as! ASTNodeObject & { children: ASTNode[], hoistDec?: ASTNode, parent?: ASTNodeObject }
    [ws, , body] := s.children as [ASTNode, ASTNode, [ASTNode, ASTLeaf, ASTNode, ASTNode][]]
    [, argInit] := s.children as [ASTNode, PipeArg, ASTNode]
    arg: PipeArg .= argInit

    children: ASTNode[] := [ws]
    comma := blockContainingStatement(s) ? ";" : ","

    let usingRef: ASTNode | null = null

    for each step, i of body
      const [leadingComment, pipe, trailingComment, expr] = step
      const returns = pipe.token is "||>"
      let ref: ASTNode?, result: ASTNode,
        returning: ASTNode | null = returns ? arg : null

      if pipe.token is "|>="
        let initRef: ASTNode?
        if i is 0
          checkValidLHS arg

          :outer switch arg.type
            when "MemberExpression"
              // If there is only a single access then we don't need a ref
              break if arg.children!.length <= 2
              continue switch
            when "CallExpression"
              const access = arg.children!.pop()
              // processAssignments will check that this is a valid
              // last access to assign to

              usingRef = makeRef()
              initRef = {
                type: "AssignmentExpression"
                children: [usingRef, " = ", arg, comma]
              } as! ASTNode

              arg = {
                type: "MemberExpression"
                children: [usingRef, access]
              }

          // assignment node
          lhs := [[
            [initRef]
            arg
            []
            { token: "=", children: [" = "] }
          ]]

          Object.assign s, {
            type: "AssignmentExpression"
            children: [lhs, children]
            names: null
            lhs
            assigned: arg
            expression: children
          } as! AssignmentExpression

          // Clone so that the same node isn't on the left and right because splice manipulation
          // moves things around and can cause a loop in the graph
          arg = clone(arg) as! PipeArg
          removeHoistDecs arg

          // except keep the ref the same
          if (arg.children![0] as { type?: string }).type is "Ref"
            arg.children![0] = usingRef!

        else
          children.unshift({
            type: "Error",
            $loc: (pipe.token as ASTNode & { $loc?: { pos: number, length: number } } as ASTNode & { $loc?: { pos: number, length: number } }).$loc,
            message: "Can't use |>= in the middle of a pipeline",
          } as! ASTNode)
      else
        if (i is 0) s.children = children

      if returns and (ref = needsRef(arg))
        // Use the existing ref if present
        usingRef = usingRef or ref
        arg = {
          type: "ParenthesizedExpression",
          children: ["(", {
            type: "AssignmentExpression"
            children: [usingRef, " = ", arg]
          } as! ASTNode, ")"],
        } as! PipeArg
        returning = usingRef

      [result, returning] = constructPipeStep
        {
          leadingComment: skipIfOnlyWS(leadingComment)
          trailingComment: skipIfOnlyWS(trailingComment)
          expr: expr as! NonNullable<ASTNode>
        }
        arg
        returning ?? null

      if result is like { type: "ReturnStatement" }
        // Attach errors/warnings if there are more steps
        if i < body.length - 1
          result.children.push({
            type: "Error",
            message: "Can't continue a pipeline after returning",
          })
        arg = result as! PipeArg
        if children.-1 is ","
          children.pop()
          children.push(";")
        break

      if returning
        arg = returning as! PipeArg
        children.push(result, comma)
      else
        arg = result as! PipeArg

    if usingRef
      s.hoistDec = {
        type: "Declaration",
        children: ["let ", usingRef],
        names: [],
      } as! ASTNode

    children.push(arg)

    // Wrap with parens because comma operator has low precedence
    if !children.some(?.type is "ReturnStatement") and children.some & is ","
      { parent } := s
      parenthesizedExpression := makeLeftHandSideExpression { ...s }
      Object.assign s, parenthesizedExpression, {
        parent
        hoistDec: undefined
      }

    // Update parent pointers
    addParentPointers(s, s.parent)

export {
  processPipelineExpressions
}
