#!/usr/bin/env civet
/**
 * show-uncovered.civet
 *
 * Reads coverage/coverage-final.json and prints uncovered code with context,
 * formatted for easy reading by humans or LLM agents.
 *
 * Usage:
 *   civet scripts/show-uncovered.civet [file-pattern] [--context N] [--branches]
 *
 * Examples:
 *   civet scripts/show-uncovered.civet
 *   civet scripts/show-uncovered.civet typescript-service
 *   civet scripts/show-uncovered.civet --context 5
 *   civet scripts/show-uncovered.civet parser.hera --branches
 *
 * With --branches: for each partial-branch line, also print which arm is
 * uncovered (e.g. "arm 0: 42 hits  arm 1: 0 hits") so you can tell which
 * side of an if/ternary needs a test.
 */

{ readFileSync, existsSync } from "fs"
{ resolve, relative } from "path"

args := process.argv.slice 2
contextIdx := args.indexOf "--context"
CONTEXT := contextIdx !== -1 ? parseInt(args[contextIdx + 1], 10) : 3
SHOW_BRANCHES := args.includes "--branches"
patternArg := args.find (a, i) => !a.startsWith("--") and (contextIdx === -1 or i !== contextIdx + 1)

coveragePath := resolve "coverage/coverage-final.json"
unless existsSync coveragePath
  console.error "No coverage data found. Run pnpm test:coverage first."
  process.exit 1

type CoverageLocation =
  line: number
  column: number
type CoverageData =
  s: Record<string, number>
  statementMap: Record<string, { start: CoverageLocation, end: CoverageLocation }>
  b: Record<string, number[]>
  branchMap: Record<string, { loc: { start: CoverageLocation, end: CoverageLocation } }>

coverage := JSON.parse(readFileSync(coveragePath, "utf8")) as Record<string, CoverageData>

for [filePath, data] of Object.entries coverage
  rel := relative process.cwd(), filePath
  continue if patternArg and !rel.includes patternArg

  // Collect uncovered statement lines (1-based)
  uncoveredLines := new Set<number>
  for [id, count] of Object.entries data.s
    if count is 0
      loc := data.statementMap[id]
      for l of [loc.start.line..loc.end.line]
        uncoveredLines.add l

  // Collect lines with uncovered branches (statement may be covered but branch not)
  // and map each line to the branch details (id + count + arm location)
  branchOnlyLines := new Set<number>
  // All branches at each line, including covered siblings, so we can show
  // "arm A: 42 hits  arm B: 0 hits" for ternaries where c8 tracks each arm
  // as a separate branch entry.
  allBranchesByLine := new Map<number, { id: string, count: number, col: number, uncovered: boolean }[]>
  for [id, counts] of Object.entries data.b
    bm := data.branchMap[id]
    loc := bm?.loc
    continue unless loc
    uncovered := counts.some (c) => c is 0
    if uncovered
      for l of [loc.start.line..loc.end.line]
        branchOnlyLines.add l unless uncoveredLines.has l
    line := loc.start.line
    count := counts[0] ?? 0
    col := (bm as any).locations?.[0]?.start?.column ?? loc.start.column
    existing := allBranchesByLine.get(line) ?? []
    existing.push { id, count, col, uncovered }
    allBranchesByLine.set line, existing

  allUncovered := new Set [...uncoveredLines, ...branchOnlyLines]

  continue if allUncovered.size is 0
  continue unless existsSync filePath

  lines := (readFileSync filePath, "utf8").split "\n"

  // Group consecutive uncovered lines into ranges
  sorted := [...allUncovered].sort (a, b) => a - b
  ranges: [number, number][] := []
  start .= sorted[0]
  end .= sorted[0]
  for i of [1...sorted.length]
    if sorted[i] <= end + 1
      end = sorted[i]
    else
      ranges.push [start, end]
      start = end = sorted[i]
  ranges.push [start, end]

  stmtCount := uncoveredLines.size
  branchCount := branchOnlyLines.size
  parts: string[] := []
  parts.push `${stmtCount} uncovered` if stmtCount
  parts.push `${branchCount} partial branch` if branchCount
  summary := `${parts.join ", "} line(s) in ${ranges.length} region(s)`

  console.log `\n${"=".repeat 60}`
  console.log `FILE: ${rel}  (${summary})`
  console.log `${"=".repeat 60}`

  // Merge nearby ranges so we don't print the same context twice
  merged := [ranges[0]]
  for i of [1...ranges.length]
    prev := merged[merged.length - 1]
    if ranges[i][0] - prev[1] <= CONTEXT * 2 + 1
      prev[1] = ranges[i][1]
    else
      merged.push ranges[i]

  for [rStart, rEnd] of merged
    from := Math.max 1, rStart - CONTEXT
    to := Math.min lines.length, rEnd + CONTEXT
    console.log `\n  Lines ${rStart}–${rEnd}:`
    for l of [from..to]
      marker := if uncoveredLines.has l
        ">>>"
      else if branchOnlyLines.has l
        "?b?"
      else
        "   "
      lineNum := String(l).padStart 4
      console.log `  ${marker} ${lineNum}: ${lines[l - 1]}`
      if SHOW_BRANCHES and allBranchesByLine.has l
        // Only report if at least one branch at this line is uncovered
        all := allBranchesByLine.get(l)!
        if all.some((b) => b.uncovered)
          summary := all
            .sort((a, b) => a.col - b.col)
            .map((b) => `col${b.col}:${b.count}${if b.uncovered then "×" else ""}`)
            .join "  "
          console.log `        ${summary}`

console.log ""
