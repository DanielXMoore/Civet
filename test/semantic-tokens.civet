{ getSemanticTokens, compile, type SemanticToken } from ../source/main.civet
assert from assert

function getTokens(src: string): SemanticToken[]
  ast := compile(src, {ast: true, sync: true})
  getSemanticTokens(ast)

function tokenText(src: string, token: SemanticToken): string
  src.substring(token.pos, token.pos + token.length)

describe "getSemanticTokens", ->
  it "returns empty array for empty input", ->
    tokens := getTokens("")
    assert.deepStrictEqual tokens, []

  it "identifies 'if' as a keyword", ->
    src := "if true then 1"
    tokens := getTokens(src)
    kwTokens := tokens.filter .group is "keyword"
    texts := kwTokens.map tokenText(src, .)
    assert texts.some((t) => t.trimEnd() is "if"), "expected 'if' keyword"

  it "identifies boolean literals as keywords", ->
    src := "x := true"
    tokens := getTokens(src)
    kwTokens := tokens.filter .group is "keyword"
    texts := kwTokens.map tokenText(src, .)
    assert texts.some((t) => t.trimEnd() is "true"), "expected 'true' keyword"

  it "identifies string literals", ->
    src := 'x := "hello world"'
    tokens := getTokens(src)
    strTokens := tokens.filter .group is "string"
    assert strTokens.length > 0, "expected string token"
    assert strTokens.some((t) => tokenText(src, t) is '"hello world"'), "expected string token text"

  it "identifies numeric literals", ->
    src := "x := 42"
    tokens := getTokens(src)
    numTokens := tokens.filter .group is "number"
    assert numTokens.length > 0, "expected number token"
    assert numTokens.some((t) => tokenText(src, t) is "42"), "expected number token text"

  it "identifies line comments", ->
    src := "// a comment\nx := 1"
    tokens := getTokens(src)
    commentTokens := tokens.filter .group is "comment"
    assert commentTokens.length > 0, "expected comment token"

  it "identifies block comments", ->
    src := "/* block */\nx := 1"
    tokens := getTokens(src)
    commentTokens := tokens.filter .group is "comment"
    assert commentTokens.length > 0, "expected comment token"

  it "identifies 'class' keyword", ->
    src := "class Foo\n  x = 1"
    tokens := getTokens(src)
    kwTokens := tokens.filter .group is "keyword"
    texts := kwTokens.map tokenText(src, .)
    assert texts.some((t) => t.trimEnd() is "class"), "expected 'class' keyword"

  it "identifies 'return' keyword", ->
    src := "f := -> return 42"
    tokens := getTokens(src)
    kwTokens := tokens.filter .group is "keyword"
    texts := kwTokens.map tokenText(src, .)
    assert texts.some((t) => t.trimEnd() is "return"), "expected 'return' keyword"

  it "returns tokens sorted by position", ->
    src := "if true then return 42"
    tokens := getTokens(src)
    for i of tokens.keys()
      if i > 0
        assert tokens[i].pos >= tokens[i - 1].pos,
          `tokens not sorted at index ${i}: ${tokens[i - 1].pos} > ${tokens[i].pos}`

  it "skips zero-length tokens", ->
    src := "if true then 1"
    tokens := getTokens(src)
    zeroLen := tokens.filter .length is 0
    assert zeroLen.length is 0, "expected no zero-length tokens"

  it "identifies 'null' as keyword", ->
    src := "x := null"
    tokens := getTokens(src)
    kwTokens := tokens.filter .group is "keyword"
    texts := kwTokens.map tokenText(src, .)
    assert texts.some((t) => t.trimEnd() is "null"), "expected 'null' keyword"

  it "identifies regexp literals", ->
    src := "r := /hello/"
    tokens := getTokens(src)
    reTokens := tokens.filter .group is "regexp"
    assert reTokens.length > 0, "expected regexp token"
