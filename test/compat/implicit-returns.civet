{testCase} from ../helper.civet

describe "-implicitReturns", ->
  testCase """
    disable via -implicitReturns
    ---
    "civet -implicitReturns"
    => "one line still returns"
    =>
      notReturned()
    -> notReturned()
    ->
      notReturned()
    function() notReturned()
    function()
      notReturned()
    function()
      if x
        notReturned()
      else
        notReturned()
    ---
    () => "one line still returns";
    () => {
      notReturned()
    };
    (function() { notReturned() });
    (function() {
      notReturned()
    });
    (function() { notReturned() });
    (function() {
      notReturned()
    });
    (function() {
      if (x) {
        notReturned()
      }
      else {
        notReturned()
      }
    })
  """

  testCase """
    parenthesized if/else if/else expression implicit return
    ---
    "civet -implicitReturns"
    o = (
      if x
        "a"
      else if y
        "b"
      else
        "c"
    )
    ---
    o = (
      (()=>{if (x) {
        return "a"
      }
      else if (y) {
        return "b"
      }
      else {
        return "c"
      }})()
    )
  """

describe "esCompat disables implicit returns", ->
  testCase """
    disables block implicit returns but keeps expression-body arrows
    ---
    "civet esCompat"
    function f
      value
    g := () =>
      value
    h := () => value
    ---
    function f() {
      value
    }
    const g = () => {
      value
    }
    const h = () => value
  """
