{testCase, throws} from ../helper.civet

describe "coffeeDiv", ->
  testCase """
    //
    ---
    "civet coffee-compat"
    a // b
    ---
    var div: (a: number, b: number) => number = (a, b) => Math.floor(a / b);
    div(a, b)
  """

  testCase """
    //=
    ---
    "civet coffee-compat"
    a //= b
    ---
    var a;var div: (a: number, b: number) => number = (a, b) => Math.floor(a / b);
    a = div(a, b)
  """

  testCase """
    //= no space on right
    ---
    "civet coffee-compat"
    a //=b
    ---
    var a;var div: (a: number, b: number) => number = (a, b) => Math.floor(a / b);
    a =div(a, b)
  """

  throws """
    do with indented reserved word
    ---
    "civet coffee-compat"
    do
      break
    ---
    ParseError
  """
