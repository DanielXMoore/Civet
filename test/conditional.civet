{testCase, throws} from ./helper.civet

describe "conditional", ->
  testCase """
    basic
    ---
    x ? y : z
    ---
    x ? y : z
  """

  testCase """
    it works with braceless inline objects
    ---
    x ? a: b : c: d
    ---
    x ? {a: b} : {c: d}
  """

  throws """
    needs space before ?
    ---
    x? y : z
    ---
    ParseError
  """

  testCase """
    indented
    ---
    x
      ? y
      : z
    ---
    x
      ? y
      : z
  """

  testCase """
    same indent
    ---
    x
    ? y
    : z
    ---
    x
    ? y
    : z
  """

  // #1933
  testCase """
    trailing ?/:
    ---
    x ?
      y :
      z
    ---
    x ?
      y :
      z
  """

  testCase """
    trailing ?/: with complex condition
    ---
    typeof token is "string" ?
      token :
      undefined
    ---
    typeof token === "string" ?
      token :
      undefined
  """

  testCase """
    chained trailing ?/:
    ---
    a ?
      b :
      c ?
        d :
        e
    ---
    a ?
      b :
      c ?
        d :
        e
  """

  // #1309
  testCase """
    indented chain
    ---
    a
      ? a.amount
      : b
      ? b.amount
      : null
    ---
    a
      ? a.amount
      : b
      ? b.amount
      : null
  """

  // #1507 — snug ternaries
  describe "snug", ->
    testCase """
      no whitespace anywhere
      ---
      a?b:c
      ---
      a?b:c
    """

    testCase """
      space before ? only (the original #1507 regression)
      ---
      a ?b :c
      ---
      a ?b :c
    """

    testCase """
      space before ? and space after :
      ---
      a ?b : c
      ---
      a ?b : c
    """

    // `a? b :c` is snug optional invocation `a?.(b :c)` (`?` followed by space
    // before any argument is `?.( ... )`); the ternary form requires `a ?b :c`.
    testCase """
      space-after `?` stays optional-call, not ternary
      ---
      x = a? b :c
      ---
      x = a?.(b(Symbol.for("c")))
    """

    testCase """
      number snug ternary
      ---
      x = 1?2:3
      ---
      x = 1?2:3
    """

    testCase """
      member access on condition
      ---
      obj.flag?x:y
      ---
      obj.flag?x:y
    """

    testCase """
      in assignment
      ---
      x = a?b:c
      ---
      x = a?b:c
    """

    testCase """
      as function argument
      ---
      f(a?b:c)
      ---
      f(a?b:c)
    """

    testCase """
      chained snug ternaries
      ---
      a?b:c?d:e
      ---
      a?b:c?d:e
    """

    // Snug `a?(...)` would consume `?(` as snug optional call; for nested,
    // parenthesize the LHS or use spaces.
    testCase """
      nested snug ternary via spaces around outer
      ---
      a ? (b?c:d) : e
      ---
      a ? (b?c:d) : e
    """

    testCase """
      half-snug then with symbol arg in else
      ---
      a ?b :c :d
      ---
      a ?b :c(Symbol.for("d"))
    """

    // Regression guard for the split `AccessStart` snug-`?` variant: the
    // disambiguation lookahead must still let `?id` fall through to property
    // access when no `:` follows.
    testCase """
      snug optional chain `a?b` without colon stays `a?.b`
      ---
      a?b
      ---
      a?.b
    """

    testCase """
      snug optional chain in larger expression stays `a?.b`
      ---
      x = a?b + 1
      ---
      x = a?.b + 1
    """

    testCase """
      optional chain stays an optional chain
      ---
      a?.b
      ---
      a?.b
    """

    testCase """
      optional chain followed by colon is not a ternary
      ---
      x = a?.b
      ---
      x = a?.b
    """

    testCase """
      snug ternary inside object value
      ---
      x = {k: a?b:c}
      ---
      x = {k: a?b:c}
    """

    testCase """
      symbol shorthand still works outside ternary
      ---
      f :foo
      ---
      f(Symbol.for("foo"))
    """

    testCase """
      member with question shorthand call still works
      ---
      a?(x)
      ---
      a?.(x)
    """
