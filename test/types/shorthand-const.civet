{testCase} from ../helper.civet

describe "[TS] shorthand const", ->
  testCase """
    works with types
    ---
    x : string := y
    ---
    const x : string = y
  """

  testCase """
    implicit object typed arrow function with declaration in body
    ---
    f: (x: T) => y := z
    ---
    ({f: (x: T) => { const y = z;return y }})
  """
