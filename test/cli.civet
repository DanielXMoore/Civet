assert from assert
path from path
{ parseArgs, makeOutputFilename, type Options, type ParsedArgs } from ../source/cli.civet
{ cli, version } from ../source/cli.civet
{ writeFile, mkdir, rm, readFile } from fs/promises
{ tmpdir } from os

function argsParse(args: string | string[], parsed: ParsedArgs): Promise<void>
  args = args.split /\s+/ if args <? 'string'
  assert.deepStrictEqual await parseArgs(args, true), parsed

type OptionsOrUndefined = {
  [P in keyof Options]: Options[P] | undefined
}

function argsOptions(args: string | string[], required: OptionsOrUndefined): Promise<void>
  args = args.split /\s+/ if args <? 'string'
  parsed := await parseArgs args, true
  for key of [ 'filenames', 'scriptArgs' ] as const
    assert.deepStrictEqual parsed[key], [], key
  if 'parseOptions' in required
    required.parseOptions?.rewriteCivetImports ??= '.civet.jsx'
  { options } := parsed
  for key in required
    key
  for key in required
    assert.deepStrictEqual
      options[key as keyof Options]
      required[key as keyof Options]
      `options.${key}`

describe 'CLI parseArgs', ->
  for version of [ '-v', '-version', '--version' ]
    it `parses ${version}`, =>
      argsOptions version, version: true

  for help of [ '-h', '-help', '--help' ]
    it `parses ${help}`, =>
      argsOptions help, help: true

  it `parses -ch`, =>
    argsOptions '-ch',
      help: true
      compile: true

  it 'parses --config', =>
    argsOptions '--config custom-config.js', config: 'custom-config.js'

  it 'parses --no-config', =>
    argsOptions '--no-config', config: false

  it 'parses --civet', =>
    argsOptions '--civet coffeeCompat', parseOptions: coffeeCompat: true

  it 'parses --civet complex', =>
    argsOptions ['--civet', 'tab=4 autoLet'],
      parseOptions:
        tab: 4
        autoLet: true

  it 'parses --civet multiple', =>
    argsOptions '--civet tab=4 --civet autoLet',
      parseOptions:
        tab: 4
        autoLet: true

  it 'overrides rewriteCivetImports', :Promise<void> =>
    argsOptions '--civet rewriteCivetImports=.js',
      parseOptions: rewriteCivetImports: '.js'

  it 'parses --comptime', =>
    argsOptions '--comptime', parseOptions: comptime: true

  it 'parses --no-comptime', =>
    argsOptions '--no-comptime', parseOptions: comptime: false

  it 'parses --comptime and --no-comptime together', =>
    await argsOptions '--comptime --no-comptime', parseOptions: comptime: false
    await argsOptions '--no-comptime --comptime', parseOptions: comptime: true

  it 'parses --ast', =>
    argsOptions '--ast', ast: true

  it 'parses --no-cache', =>
    argsOptions '--no-cache', noCache: true

  it 'parses --inline-map', =>
    argsOptions '--inline-map', inlineMap: true

  it 'parses --js', =>
    argsOptions '--js', js: true

  it 'parses --hits', =>
    argsOptions '--hits hits.out', hits: 'hits.out'

  it 'parses --trace', =>
    argsOptions '--trace trace.out', trace: 'trace.out'

  it 'parses --typecheck', =>
    argsOptions '--typecheck',
      typecheck: true
      typescript: true
      run: false
      repl: undefined

  for emit of [ '--emit-declaration', '--emitDeclaration' ]
    it `parses ${emit}`, =>
      argsOptions emit,
        emitDeclaration: true
        typescript: true
        run: false
        repl: undefined

    it `parses --typecheck with ${emit}`, =>
      argsOptions `--typecheck ${emit}`,
        emitDeclaration: true
        typescript: true
        run: false
        repl: undefined

  it 'launches repl with TTY', =>
    assert.deepStrictEqual await parseArgs([], true),
      filenames: []
      scriptArgs: []
      options:
        repl: true
        run: true
        parseOptions: rewriteCivetImports: '.civet.jsx'

  it 'pipe without TTY', =>
    assert.deepStrictEqual await parseArgs([], false),
      filenames: ['-']
      scriptArgs: []
      options:
        compile: true
        run: false
        parseOptions: rewriteCivetImports: '.civet.jsx'

  for compile of [ '-c', '--compile' ]
    it `parses ${compile}`, =>
      argsOptions compile, compile: true

    it `parses ${compile} with filename`, =>
      argsParse `${compile} filename.civet`,
        filenames: [ 'filename.civet' ]
        scriptArgs: []
        options:
          compile: true
          run: false
          parseOptions: rewriteCivetImports: '.civet.jsx'

    it `parses ${compile} with filenames`, =>
      argsParse `${compile} one.civet two.civet three.civet`,
        filenames: [ 'one.civet', 'two.civet', 'three.civet' ]
        scriptArgs: []
        options:
          compile: true
          run: false
          parseOptions: rewriteCivetImports: '.civet.jsx'

  for output of [ '-o', '--output' ]
    it `parses ${output} with -`, =>
      argsOptions `${output} -`,
        output: '-'
        outputDir: undefined
        outputExt: undefined
        outputPath: undefined
        parseOptions: rewriteCivetImports: '.civet.jsx'

    it `parses ${output} with filename`, =>
      argsOptions `${output} filename.js`,
        output: 'filename.js'
        outputDir: undefined
        outputExt: '.js'
        outputPath: path.parse 'filename.js'
        parseOptions: rewriteCivetImports: '.js'

    it `parses ${output} with pathname`, =>
      argsOptions `${output} ./filename.js`,
        output: './filename.js'
        outputDir: undefined
        outputExt: '.js'
        outputPath: path.parse './filename.js'
        parseOptions: rewriteCivetImports: '.js'

    it `parses ${output} with existing directory`, =>
      argsOptions `${output} .`,
        output: '.'
        outputDir: '.'
        outputExt: undefined
        outputPath: undefined
        parseOptions: rewriteCivetImports: '.civet.jsx'

    it `parses ${output} with new directory`, =>
      argsOptions `${output} does-not-exist/`,
        output: 'does-not-exist/'
        outputDir: 'does-not-exist/'
        outputExt: undefined
        outputPath: undefined
        parseOptions: rewriteCivetImports: '.civet.jsx'

    it `parses ${output} with extension`, =>
      argsOptions `${output} .js`,
        output: '.js'
        outputDir: undefined
        outputExt: '.js'
        outputPath: undefined
        parseOptions: rewriteCivetImports: '.js'

    it `parses ${output} with complex extension`, =>
      argsOptions `${output} .civet.js`,
        output: '.civet.js'
        outputDir: undefined
        outputExt: '.civet.js'
        outputPath: undefined
        parseOptions: rewriteCivetImports: '.civet.js'

    it `parses ${output} with directory and extension`, =>
      argsOptions `${output} ./.js`,
        output: './.js'
        outputDir: '.'
        outputExt: '.js'
        outputPath: undefined
        parseOptions: rewriteCivetImports: '.js'

    for ext of ['.js', '.jsx', '.mjs', '.cjs']
      it `${output} ${ext} implies --js`, =>
        argsOptions `${output} ${ext}`,
          outputExt: ext
          js: true

    for ext of ['.ts', '.tsx', '.mts', '.cts']
      it `${output} ${ext} does not imply --js`, =>
        argsOptions `${output} ${ext}`,
          outputExt: ext
          js: undefined

    it `${output} filename.jsx implies --js`, =>
      argsOptions `${output} out.jsx`,
        outputExt: '.jsx'
        js: true

  it 'resolves output filename for multi-dot input with -o .ts', =>
    inputFilename := 'src/lib/something.lib.civet'
    {filenames, options} := await parseArgs ['-c', '-o', '.ts', inputFilename], true
    expectedPath := path.parse inputFilename
    expectedPath.base = ""
    expectedPath.ext = '.ts'

    outputFilename := makeOutputFilename filenames[0], options
    assert.equal outputFilename, path.normalize path.format expectedPath
    assert.doesNotMatch outputFilename, /\.civet/

  it `parses -e`, =>
    argsOptions '-e console.log("hello")',
      eval: 'console.log("hello")'
      run: true
      repl: undefined

  it `parses -c -e`, =>
    argsOptions '-c -e console.log("hello")',
      eval: 'console.log("hello")'
      compile: true
      run: false
      repl: undefined

  it 'parses -- separator with filenames', =>
    argsParse ['--compile', '--', 'file.civet'],
      filenames: ['file.civet']
      scriptArgs: []
      options:
        compile: true
        run: false
        parseOptions: rewriteCivetImports: '.civet.jsx'

  it 'parses -- separator with multiple filenames', =>
    argsParse ['--compile', '--', 'a.civet', 'b.civet'],
      filenames: ['a.civet', 'b.civet']
      scriptArgs: []
      options:
        compile: true
        run: false
        parseOptions: rewriteCivetImports: '.civet.jsx'

  it 'parses -- separator with nothing after', =>
    argsParse ['--compile', '--'],
      filenames: []
      scriptArgs: []
      options:
        compile: true
        repl: true
        run: false
        parseOptions: rewriteCivetImports: '.civet.jsx'

  it 'treats bare filename as run mode', =>
    argsParse ['script.civet'],
      filenames: ['script.civet']
      scriptArgs: []
      options:
        run: true
        parseOptions: rewriteCivetImports: '.civet.jsx'

  it 'treats bare filename with extra args as scriptArgs', =>
    argsParse ['script.civet', 'arg1', 'arg2'],
      filenames: ['script.civet']
      scriptArgs: ['arg1', 'arg2']
      options:
        run: true
        parseOptions: rewriteCivetImports: '.civet.jsx'

  it 'treats - as stdin filename in compile mode', =>
    argsParse ['-c', '-'],
      filenames: ['-']
      scriptArgs: []
      options:
        compile: true
        run: false
        parseOptions: rewriteCivetImports: '.civet.jsx'

  it 'parses --typecheck with filename (no REPL, no pipe default)', =>
    argsParse ['--typecheck', 'file.civet'],
      filenames: ['file.civet']
      scriptArgs: []
      options:
        typecheck: true
        typescript: true
        run: false
        parseOptions: rewriteCivetImports: '.civet.jsx'

  it 'parses --eval with --typecheck', =>
    argsOptions '--typecheck -e "code"',
      eval: '"code"'
      typecheck: true
      typescript: true
      run: false
      repl: undefined

  it 'parses --ast sets run to false', =>
    argsOptions '--ast',
      ast: true
      run: false

  it 'parses --ast with filename (run is false)', =>
    argsParse ['--ast', 'file.civet'],
      filenames: ['file.civet']
      scriptArgs: []
      options:
        ast: true
        run: false
        parseOptions: rewriteCivetImports: '.civet.jsx'

  it 'parses combined flags -cv (compile + version)', =>
    // -cv splits into -c and -v
    argsOptions ['-cv'],
      version: true
      compile: true

  it 'parses combined flags -vc (version + compile)', =>
    // -vc splits into -v and -c
    argsOptions ['-vc'],
      version: true
      compile: true

  it '--js sets rewriteCivetImports default to .civet.jsx', =>
    argsOptions '--js',
      js: true
      parseOptions: rewriteCivetImports: '.civet.jsx'

  it '--js with -o .ts sets rewriteCivetImports to .ts', =>
    argsOptions '--js -o .ts',
      js: true
      outputExt: '.ts'
      parseOptions: rewriteCivetImports: '.ts'

  it 'parses --no-cache with --js together', =>
    argsOptions '--no-cache --js',
      noCache: true
      js: true

  it 'parses multiple --civet flags accumulate', =>
    argsOptions '--civet coffeeCompat --civet autoLet',
      parseOptions:
        coffeeCompat: true
        autoLet: true

  it 'parses --typecheck with --compile', =>
    argsOptions '--typecheck --compile',
      typecheck: true
      typescript: true
      compile: true
      run: false
      repl: undefined

describe 'CLI makeOutputFilename', ->
  async function makeOutput(args: string[], inputFilename = 'input.civet'): Promise<string>
    { options } := await parseArgs args, true
    makeOutputFilename inputFilename, options

  it 'uses .tsx by default', =>
    assert.equal await makeOutput(['-c', 'input.civet']), 'input.civet.tsx'

  it 'uses .jsx when --js is set', =>
    assert.equal await makeOutput(['-c', '--js', 'input.civet']), 'input.civet.jsx'

  it 'applies outputExt from -o .ts', =>
    assert.equal await makeOutput(['-c', '-o', '.ts', 'input.civet']), 'input.ts'

  it 'applies outputDir from -o ./', =>
    result := await makeOutput ['-c', '-o', './', 'input.civet']
    // -o ./ puts the output file in current directory
    assert.equal path.basename(result), 'input.civet.tsx'
    assert.equal path.dirname(result), '.'

  it 'applies outputPath from -o output.ts', =>
    assert.equal await makeOutput(['-c', '-o', 'output.ts', 'input.civet']), 'output.ts'

  it 'applies outputDir with extension from -o dir/.ts', =>
    result := await makeOutput ['-c', '-o', 'outdir/.ts', 'input.civet']
    assert.equal path.extname(result), '.ts'
    assert.equal path.dirname(result), 'outdir'

  it 'preserves nested input directory when no output specified', =>
    result := await makeOutput ['-c'], 'src/lib/foo.civet'
    assert.equal path.basename(result), 'foo.civet.tsx'
    assert.equal path.dirname(result), path.join 'src', 'lib'

  it 'uses .jsx extension for nested file with --js', =>
    result := await makeOutput ['-c', '--js'], 'src/lib/foo.civet'
    assert.equal path.extname(result), '.jsx'
    assert.equal path.dirname(result), path.join 'src', 'lib'

  it 'applies outputDir to nested input file', =>
    result := await makeOutput ['-c', '-o', 'dist/'], 'src/foo.civet'
    // -o dist/ redirects output to dist directory
    assert.equal path.dirname(result), 'dist'
    assert.equal path.basename(result), 'foo.civet.tsx'

  it 'applies outputPath overrides directory from nested input', =>
    result := await makeOutput ['-c', '-o', 'out/result.ts'], 'src/lib/foo.civet'
    assert.equal result, path.join 'out', 'result.ts'

  it 'applies outputExt .js to nested file', =>
    result := await makeOutput ['-c', '-o', '.js'], 'src/foo.civet'
    assert.equal path.extname(result), '.js'
    assert.equal path.dirname(result), 'src'
    assert.doesNotMatch result, /\.civet/

  it 'applies outputDir and outputExt together to nested input', =>
    result := await makeOutput ['-c', '-o', 'build/.ts'], 'src/deep/file.civet'
    assert.equal path.extname(result), '.ts'
    assert.equal path.dirname(result), 'build'
    assert.doesNotMatch result, /\.civet/

function captureProcess(fn: => Promise<unknown>): Promise<{exitCode: number?, stdOut: string, stdErr: string}>
  orig := {
    stdout: process.stdout.write
    stderr: process.stderr.write
    exit: process.exit
  }

  stdOutChunks: string[] := []
  process.stdout.write = (chunk: any) =>
    stdOutChunks.push Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk)
    true

  stdErrChunks: string[] := []
  process.stderr.write = (chunk: any) =>
    stdErrChunks.push Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk)
    true

  let exitCode : number?
  exit := {}
  process.exit = (code?: number) =>
    exitCode = code
    throw exit

  try
    await fn()
  catch err: any
    throw err unless err is exit
  finally
    if exitCode is undefined
      code := process.exitCode
      exitCode = switch code
        <? "string"
          Number(code)
        else
          code ?? undefined

    process.exit = orig.exit
    process.stdout.write = orig.stdout
    process.stderr.write = orig.stderr

  {
    exitCode
    stdOut: stdOutChunks.join('')
    stdErr: stdErrChunks.join('')
  }

describe "CLI version()", ->
  it "returns a non-empty semver string", ->
    v := await version()

    assert /^\d+\.\d+\.\d+/.test(v), "version looks like semver: " + v

describe "CLI --version flag", ->
  it "prints version to stdout and exits 0", ->
    { exitCode, stdOut } := await captureProcess =>
      await cli ['--version']

    assert /\d+\.\d+\.\d+/.test(stdOut.trim()), "stdout contains version: " + stdOut
    assert.equal exitCode, 0

describe "CLI --help flag", ->
  it "prints help text to stderr and exits 0", ->
    { exitCode, stdErr } := await captureProcess =>
      await cli ['--help']

    assert stdErr.includes('Usage'), "help contains 'Usage'"
    assert stdErr.includes('--compile'), "help mentions --compile"
    assert.equal exitCode, 0

describe "CLI --eval --compile", ->
  it "compiles Civet code to stdout", ->
    { stdOut } := await captureProcess =>
      await cli ['-c', '--no-config', '--eval', 'x := 1']

    assert stdOut.includes('x'), "compiled output contains variable: " + stdOut

  it "--js strips TypeScript type annotations", ->
    { stdOut } := await captureProcess =>
      await cli ['-c', '--no-config', '--js', '--eval', 'x: number := 5']

    assert !stdOut.includes(': number'), "type annotation stripped from output"

describe "CLI --ast", ->
  it "outputs valid JSON AST for eval code", ->
    { stdOut } := await captureProcess =>
      await cli ['--ast', '--no-config', '--eval', 'x := 1']
    parsed := JSON.parse stdOut

    assert.equal parsed.type, "BlockStatement"

describe "CLI file tests", ->
  // Temporary directory for testing files
  let tmpDir: string
  fileNum .= 0
  before ->
    tmpDir = path.join tmpdir(), "civet-cli-compile-test-" + Math.random().toString(36).substring(2, 15)
    await mkdir tmpDir, { recursive: true }

  after ->
    await rm tmpDir, { recursive: true, force: true }

  function makeCivetTempFile(content: string)
    filePath := path.join tmpDir, `input-${fileNum++}.civet`
    await writeFile filePath, content

    filePath

  describe "readFiles (via compile)", ->
    it "reads and compiles a real .civet file", ->
      inputFile := await makeCivetTempFile "z := 99\n"

      { stdOut } := await captureProcess =>
        await cli ['-c', '--no-config', '-o', '-', inputFile]

      assert stdOut.includes('z'), "compiled file output contains variable: " + stdOut

    it "reports error for missing file via stderr", ->
      { stdErr, exitCode } := await captureProcess =>
        await cli ['-c', '--no-config', '/nonexistent/missing-file.civet']

      assert.equal exitCode, 1
      assert stdErr.length > 0, "stderr had output for missing file"

  describe "compile to file", ->
    it "writes .civet.tsx output file by default", ->
      inputFile := await makeCivetTempFile "x := 1\n"
      await cli ['-c', '--no-config', inputFile]

      content := await readFile inputFile + ".tsx", 'utf8'
      assert content.includes('x'), "output file contains variable"

    it "respects -o .js extension override", ->
      inputFile := await makeCivetTempFile "y := 2\n"

      await cli ['-c', '--no-config', '-o', '.js', inputFile]

      expectedOut := inputFile.replace(/\.civet$/, '.js')
      content := await readFile expectedOut, 'utf8'
      assert content.includes('y'), "output .js file contains variable"

    it "respects -o dir/ redirect", ->
      inputFile := await makeCivetTempFile "w := 3\n"
      subDir := path.dirname inputFile
      await mkdir subDir, { recursive: true }

      await cli ['-c', '--no-config', '-o', subDir + '/', inputFile]

      expectedOut := inputFile + ".tsx"
      content := await readFile expectedOut, 'utf8'
      assert content.includes('w'), "output in dir contains variable"

    it "creates output directory if it does not exist", ->
      inputFile := await makeCivetTempFile "v := 4\n"
      newDir := path.join path.dirname(inputFile), "new-dir"

      await cli ['-c', '--no-config', '-o', newDir + '/', inputFile]

      expectedOut := path.join newDir, path.basename(inputFile) + ".tsx"
      content := await readFile expectedOut, 'utf8'
      assert content.includes('v'), "output in new dir contains variable"

    // Covers lines 582-584: writeFile failure branch
    it "reports write failure when output file is read-only", ->
      { chmod } := await import 'fs/promises'
      inputFile := await makeCivetTempFile "q := 9\n"
      // Pre-create the output file as a regular file so parseArgs routes it
      // through the outputPath branch (not outputDir). Then chmod it 0o400
      // so writeFile fails with EACCES.
      readOnlyOut := path.join tmpDir, `readonly-${fileNum++}.js`
      await writeFile readOnlyOut, ''
      await chmod readOnlyOut, 0o400
      try
        { exitCode, stdErr } := await captureProcess =>
          await cli ['-c', '--no-config', '-o', readOnlyOut, inputFile]
        assert stdErr.includes('failed to write'), "stderr mentions write failure: " + stdErr
        assert exitCode? and exitCode > 0, "exitCode > 0: " + exitCode
      finally
        await chmod readOnlyOut, 0o600

  describe "error handling", ->
    it "prints error for invalid Civet syntax and sets non-zero exit code", ->
      inputFile := await makeCivetTempFile "}\n"
      await writeFile inputFile, "}\n"

      { stdErr, exitCode } := await captureProcess =>
        await cli ['-c', '--no-config', inputFile]

      assert.equal exitCode, 1
      assert stdErr.length > 0, "stderr had compile error output"

    it "prints error for unknown CLI flag", ->
      { exitCode, stdErr } := await captureProcess =>
        await cli ['--unknown-xyz-flag-abc', '--eval', 'x := 1']

      assert.equal exitCode, 1
      assert stdErr.toLowerCase().includes('invalid'), "stderr mentions invalid argument: " + stdErr

// Covers lines 537-541: EPIPE/EOF stdout error handler.
// The handler is installed once by the first cli() call that goes past the
// options.repl early return. We invoke the registered listener directly.
describe "CLI stdout error handler", ->
  async function ensureInstalled(): Promise<void>
    // Any cli() call (compile -e) registers the listener idempotently.
    await captureProcess => await cli ['-c', '--no-config', '-e', 'x := 1']

  function getListener(): (e: {code: string}) => void
    listeners := process.stdout.listeners 'error'
    assert listeners.length > 0, "stdout error listener installed"
    listeners[listeners.length - 1] as (e: {code: string}) => void

  it "exits 0 for EPIPE on stdout", ->
    await ensureInstalled()
    listener := getListener()
    { exitCode } := await captureProcess =>
      listener code: 'EPIPE'
    assert.equal exitCode, 0

  it "exits 0 for EOF on stdout", ->
    await ensureInstalled()
    listener := getListener()
    { exitCode } := await captureProcess =>
      listener code: 'EOF'
    assert.equal exitCode, 0

  it "logs and exits 1 for other stdout errors", ->
    await ensureInstalled()
    listener := getListener()
    { exitCode, stdErr } := await captureProcess =>
      listener code: 'ENOSPC'
    assert.equal exitCode, 1
    assert stdErr.length > 0, "stderr had error output"

// Exercises lines 526-527 (run mode sets js/inlineMap), 586-592 (esm detection
// on output without await/import/export keywords), and the else branch at 646
// that falls through to module._compile. `module` is undefined in ESM-loaded
// tests, so the branch eventually throws — but the lines leading up to that
// are hit and counted.
describe "CLI run mode (cli)", ->
  // The ESM run-mode branch writes a .stdin-<pid>.civet temp file before
  // trying to fork a child process; that fork fails in ESM-loaded tests
  // (no __dirname), so the temp file can be left behind. Clean it up.
  after ->
    { readdir, unlink } := await import 'fs/promises'
    for entry of await readdir process.cwd()
      if /^\.stdin-\d+\.civet$/.test entry
        try
          await unlink entry

  it "invokes run mode and sets js/inlineMap defaults", ->
    let err: any
    await captureProcess =>
      try
        await cli ['-e', 'x := 1', '--no-config']
      catch e
        err = e
    assert err?, "run mode attempted to execute; cli threw: " + err?.message

  // Covers lines 592-597: esm detection (output mentions await/import/export)
  // triggers re-parsing for lib.hasAwait/hasImportDeclaration/hasExportDeclaration.
  it "detects ESM-ness of run-mode output containing top-level await", ->
    let err: any
    await captureProcess =>
      try
        await cli ['-e', 'await Promise.resolve(1)', '--no-config']
      catch e
        err = e
    assert err?, "ESM run-mode attempted to execute; cli threw: " + err?.message

  // Covers line 596: hasImportDeclaration probed when output has `import`.
  it "detects ESM-ness via import declaration (no await)", ->
    let err: any
    await captureProcess =>
      try
        await cli ['-e', 'import fs from "node:fs"', '--no-config']
      catch e
        err = e
    assert err?, "import branch ran; cli threw: " + err?.message

  // Covers line 597: hasExportDeclaration probed when output has `export` only.
  it "detects ESM-ness via export declaration (no await, no import)", ->
    let err: any
    await captureProcess =>
      try
        await cli ['-e', 'export x := 1', '--no-config']
      catch e
        err = e
    assert err?, "export branch ran; cli threw: " + err?.message

describe "CLI piped stdin", ->
  it "compiles Civet code read from piped stdin to stdout", ->
    origStdin := process.stdin
    try
      async function* gen()
        yield "wPiped := 7\n"
      mockStdin :=
        isTTY: false
        setEncoding: (_enc: string) => undefined
        [Symbol.asyncIterator]: => gen()
      Object.defineProperty process, 'stdin',
        value: mockStdin
        configurable: true
      { stdOut } := await captureProcess =>
        await cli ['-c', '--no-config', '-']
      assert stdOut.includes('wPiped'), "piped stdin output contains variable: " + stdOut
    finally
      Object.defineProperty process, 'stdin',
        value: origStdin
        configurable: true


describe "CLI --config", ->
  let tmpDir: string
  fileNum .= 0
  before ->
    tmpDir = path.join tmpdir(), "civet-cli-config-test-" + Math.random().toString(36).substring(2, 15)
    await mkdir tmpDir, { recursive: true }
  after ->
    await rm tmpDir, { recursive: true, force: true }

  it "loads --config JSON file with parseOptions", ->
    configPath := path.join tmpDir, "config-${fileNum++}.json"
    await writeFile configPath, JSON.stringify({parseOptions: {autoLet: true}})
    { stdOut } := await captureProcess =>
      await cli ['-c', '--config', configPath, '-e', 'x = 1']
    assert stdOut.includes('let'), "autoLet from config applied: " + stdOut

  it "deep merges --config parseOptions with --civet flag", ->
    configPath := path.join tmpDir, "config-${fileNum++}.json"
    await writeFile configPath, JSON.stringify({parseOptions: {autoLet: true}})
    // Use --civet to supply an additional parseOption; config's autoLet should remain
    { stdOut, exitCode } := await captureProcess =>
      await cli ['-c', '--config', configPath, '--civet', 'tab=2', '-e', 'x = 1']
    assert.equal exitCode, 0, "merged config + --civet succeeded"
    assert stdOut.includes('let'), "autoLet from config still applied after merge: " + stdOut

  it "auto-discovers config when neither --config nor --no-config given", ->
    // Put a config in tmpDir and cd there
    configPath := path.join tmpDir, "civetconfig.json"
    await writeFile configPath, JSON.stringify({parseOptions: {autoLet: true}})
    origCwd := process.cwd()
    try
      process.chdir tmpDir
      { stdOut, exitCode } := await captureProcess =>
        await cli ['-c', '-e', 'x = 1']
      assert.equal exitCode, 0
      assert stdOut.includes('let'), "auto-discovered config applied autoLet: " + stdOut
    finally
      process.chdir origCwd

describe "CLI --typecheck", ->
  let tmpDir: string
  fileNum .= 0
  before ->
    // Place tmp files inside the project so TypeScript's rootDir accepts them
    tmpDir = path.join process.cwd(), "test", "infra", "tmp-cli-typecheck-" + Math.random().toString(36).substring(2, 15)
    await mkdir tmpDir, { recursive: true }
  after ->
    await rm tmpDir, { recursive: true, force: true }

  function makeCivetTempFile(content: string): string
    filePath := path.join tmpDir, `input-${fileNum++}.civet`
    await writeFile filePath, content
    filePath

  it "typechecks a valid .civet file without errors", :any ->
    @timeout 30000
    inputFile := await makeCivetTempFile "x: number := 42\n"
    { exitCode, stdErr } := await captureProcess =>
      await cli ['--typecheck', '--no-config', inputFile]
    assert.equal exitCode ?? 0, 0, "valid file typechecks cleanly; stderr: " + stdErr

  it "reports TypeScript diagnostics for type errors", :any ->
    @timeout 30000
    inputFile := await makeCivetTempFile 'x: number := "not a number"\n'
    { exitCode } := await captureProcess =>
      await cli ['--typecheck', '--no-config', inputFile]
    // Non-zero exit due to TS diagnostics
    assert exitCode? and exitCode > 0, "typecheck reported errors via exitCode: " + exitCode

  it "lints whole project when --typecheck is invoked with no filenames", :any ->
    // Regression guard: pre-fix, `civet --typecheck` with no args silently
    // succeeded because unplugin's TSService had discoverProjectFiles=false
    // and an empty fsMap, leaving the program with no project files to
    // typecheck.  CLI now sets discoverProjectFiles=true when filenames is
    // empty so the tsconfig include set drives the scope.
    @timeout 30000
    isolated := path.join tmpDir, "lint-no-args"
    await mkdir isolated, { recursive: true }
    await writeFile path.join(isolated, 'tsconfig.json'), JSON.stringify({
      compilerOptions: {
        target: 'ES2022'
        module: 'ESNext'
        moduleResolution: 'Bundler'
        jsx: 'preserve'
        allowJs: true
        strict: true
        noEmit: true
      }
      include: ['src']
    })
    await mkdir path.join(isolated, 'src'), { recursive: true }
    await writeFile path.join(isolated, 'src/bad.civet'), 'x: number := "wrong"\n'

    cwd := process.cwd()
    process.chdir isolated
    try
      { exitCode } := await captureProcess =>
        await cli ['--typecheck', '--no-config']
      assert exitCode? and exitCode > 0,
        "no-args --typecheck must surface project-wide type errors via exitCode: " + exitCode
    finally
      process.chdir cwd

  it "--max-errors lets a project carry a baseline without failing CI", :any ->
    // Two type errors in a single file; --max-errors 5 lets us pass.
    @timeout 30000
    inputFile := await makeCivetTempFile 'x: number := "wrong"\ny: number := "wrong"\n'
    { exitCode, stdErr } := await captureProcess =>
      await cli ['--typecheck', '--max-errors', '5', '--no-config', inputFile]
    assert.equal exitCode ?? 0, 0,
      "--max-errors 5 should accept ≤5 errors; stderr: " + stdErr
    assert stdErr.includes("Within baseline of 5"),
      "expected the baseline-not-failing message; got: " + stdErr

  it "--max-errors below the diagnostic count still fails", :any ->
    @timeout 30000
    inputFile := await makeCivetTempFile 'x: number := "wrong"\ny: number := "wrong"\n'
    { exitCode } := await captureProcess =>
      await cli ['--typecheck', '--max-errors', '1', '--no-config', inputFile]
    assert exitCode? and exitCode > 0,
      "--max-errors 1 should fail with 2 errors over baseline; exit was: " + exitCode

  it "CIVET_TYPECHECK_MAX_ERRORS env applies the same threshold", :any ->
    @timeout 30000
    inputFile := await makeCivetTempFile 'x: number := "wrong"\n'
    process.env.CIVET_TYPECHECK_MAX_ERRORS = '5'
    try
      { exitCode, stdErr } := await captureProcess =>
        await cli ['--typecheck', '--no-config', inputFile]
      assert.equal exitCode ?? 0, 0,
        "env baseline should accept the diagnostic; stderr: " + stdErr
    finally
      delete process.env.CIVET_TYPECHECK_MAX_ERRORS

  it "--max-errors 1 produces the singular `diagnostic` message form", :any ->
    // Covers the `threshold > 1 ? 's' : ''` else arm.
    @timeout 30000
    inputFile := await makeCivetTempFile 'x: number := "wrong"\n'
    { stdErr } := await captureProcess =>
      await cli ['--typecheck', '--max-errors', '1', '--no-config', inputFile]
    assert stdErr.includes("Within baseline of 1 TypeScript diagnostic;"),
      "expected singular form; got: " + stdErr

  it "rejects --max-errors with a missing value (end of argv)", ->
    // Covers the `args[++i] ?? ''` fallback when --max-errors is the last
    // argument with no value following.
    { exitCode, stdErr } := await captureProcess =>
      await cli ['--typecheck', '--max-errors']
    assert exitCode? and exitCode > 0,
      "missing --max-errors value should exit non-zero; got: " + exitCode
    assert stdErr.includes("Invalid value for --max-errors"),
      "expected the validation message; got: " + stdErr

  it "--tsbuildinfo persists incremental analysis between runs", :any ->
    @timeout 60000
    isolated := path.join tmpDir, "tsbuildinfo-isolated"
    await mkdir isolated, { recursive: true }
    await writeFile path.join(isolated, 'tsconfig.json'), JSON.stringify({
      compilerOptions: {
        target: 'ES2022'
        module: 'ESNext'
        moduleResolution: 'Bundler'
        jsx: 'preserve'
        allowJs: true
        strict: true
        noEmit: true
      }
      include: ['src']
    })
    await mkdir path.join(isolated, 'src'), { recursive: true }
    await writeFile path.join(isolated, 'src/clean.civet'), 'x: number := 42\nconsole.log x\n'

    cwd := process.cwd()
    process.chdir isolated
    try
      buildInfoPath := path.join isolated, '.tsbuildinfo'
      // Cold run — no cache, should write the file.
      await captureProcess => await cli ['--typecheck', '--tsbuildinfo', '.tsbuildinfo', '--no-config']
      const fs2 = await import 'node:fs/promises'
      stat1 := await fs2.stat buildInfoPath
      assert stat1.size > 0, "tsbuildinfo should be written on cold run"
      // Warm run with no source change — same content (same hash).
      await captureProcess => await cli ['--typecheck', '--tsbuildinfo', '.tsbuildinfo', '--no-config']
      stat2 := await fs2.stat buildInfoPath
      assert.equal stat2.size, stat1.size,
        "tsbuildinfo should be identical between unchanged runs (size: " + stat2.size + " vs " + stat1.size + ")"
    finally
      process.chdir cwd

  it "rejects --tsbuildinfo with a missing PATH", ->
    { exitCode, stdErr } := await captureProcess =>
      await cli ['--typecheck', '--tsbuildinfo']
    assert exitCode? and exitCode > 0, "missing PATH should exit non-zero"
    assert stdErr.includes("Missing PATH after --tsbuildinfo"),
      "expected validation message; got: " + stdErr

  it "rejects --tsbuildinfo immediately followed by another flag", ->
    { exitCode, stdErr } := await captureProcess =>
      await cli ['--typecheck', '--tsbuildinfo', '--no-config']
    assert exitCode? and exitCode > 0, "PATH starting with `-` should exit non-zero"
    assert stdErr.includes("Missing PATH after --tsbuildinfo"),
      "expected validation message; got: " + stdErr

  it "rejects --max-errors with a non-numeric value", ->
    // parseArgs accumulates `errors` and process.exit's on any parse error;
    // captureProcess intercepts the exit so the test can observe it.
    { exitCode, stdErr } := await captureProcess =>
      await cli ['--typecheck', '--max-errors', 'oops', 'foo.civet']
    assert exitCode? and exitCode > 0,
      "non-numeric --max-errors should exit non-zero; got: " + exitCode
    assert stdErr.includes("Invalid value for --max-errors"),
      "expected the validation message; got: " + stdErr

  // Covers line 514: ts: if options.js then 'civet' else 'preserve'
  it "typechecks with --js (strips types) without errors", :any ->
    @timeout 30000
    inputFile := await makeCivetTempFile "x := 42\n"
    { exitCode, stdErr } := await captureProcess =>
      await cli ['--typecheck', '--js', '--no-config', inputFile]
    assert.equal exitCode ?? 0, 0, "--typecheck --js succeeds; stderr: " + stdErr

  // Covers line 517 (outputExt?.replace → '.d.ts') plus emitFile branch (666-667)
  it "emits .d.ts declaration files with --emit-declaration -o .ts", :any ->
    @timeout 30000
    { readdir } := await import 'fs/promises'
    // Work in an isolated directory with its own tsconfig so `noEmit: false`
    // allows `.d.ts` files to actually be written.
    isolated := path.join tmpDir, "decl-isolated"
    await mkdir isolated, { recursive: true }
    await writeFile path.join(isolated, 'tsconfig.json'), JSON.stringify({
      compilerOptions: {
        target: 'ES2022'
        module: 'ESNext'
        moduleResolution: 'Bundler'
        declaration: true
        emitDeclarationOnly: true
        noEmit: false
        skipLibCheck: true
        strict: false
        jsx: 'preserve'
        allowImportingTsExtensions: true
      }
    })
    inputFile := path.join isolated, "decl-input.civet"
    await writeFile inputFile, "export x: number := 42\n"
    outExt := path.join '.', '.ts'  // becomes outputExt '.ts'

    origCwd := process.cwd()
    try
      process.chdir isolated
      { exitCode, stdErr, stdOut } := await captureProcess =>
        await cli ['--emit-declaration', '--no-config', '-o', outExt, 'decl-input.civet']
      files := await readdir isolated
      declFiles := files.filter (f: string) => f.endsWith '.d.ts'
      assert declFiles.length > 0, `.d.ts emitted; got: ${JSON.stringify files}; exitCode=${exitCode}; stdErr=${stdErr}; stdOut=${stdOut}`
    finally
      process.chdir origCwd

