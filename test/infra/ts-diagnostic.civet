assert from assert

{ remapPosition, remapPositionStrict, remapRange, flattenDiagnosticMessageText, type SourcemapLines } from ../../source/ts-diagnostic.civet

describe "ts-diagnostic", ->
  describe "remapPosition", ->
    it "returns position as-is when no sourcemapLines provided", ->
      pos := { line: 3, character: 7 }
      assert.deepEqual remapPosition(pos), pos

    it "returns position as-is when sourcemapLines is empty array", ->
      pos := { line: 0, character: 5 }
      assert.deepEqual remapPosition(pos, []), pos

    it "returns position as-is when line has no mapping entries", ->
      pos := { line: 0, character: 5 }
      assert.deepEqual remapPosition(pos, [[]]), pos

    it "returns position as-is when line index is out of bounds", ->
      pos := { line: 5, character: 3 }
      assert.deepEqual remapPosition(pos, [[]]), pos

    it "returns original position when only column-delta mappings (length 1) exist", ->
      pos := { line: 0, character: 4 }
      assert.deepEqual remapPosition(pos, [[[4]]]), pos

    it "remaps position using a 4-element mapping", ->
      pos := { line: 0, character: 0 }
      assert.deepEqual remapPosition(pos, [[[0, 0, 2, 5]]]), { line: 2, character: 5 }

    it "applies character offset beyond mapping anchor", ->
      pos := { line: 0, character: 4 }
      assert.deepEqual remapPosition(pos, [[[0, 0, 1, 3]]]), { line: 1, character: 7 }

    it "picks the last 4-element mapping before the queried position", ->
      // [2] has no source info; [2, 0, 0, 10] anchors at cumulative col 4; querying col 5 -> src col 11
      pos := { line: 0, character: 5 }
      sourcemapLines: SourcemapLines := [[[2], [2, 0, 0, 10]]]
      assert.deepEqual remapPosition(pos, sourcemapLines), { line: 0, character: 11 }

    it "handles multiple lines independently", ->
      sourcemapLines: SourcemapLines := [
        [[0, 0, 0, 0]]
        [[0, 0, 2, 0]]
      ]
      assert.deepEqual remapPosition({ line: 0, character: 1 }, sourcemapLines), { line: 0, character: 1 }
      assert.deepEqual remapPosition({ line: 1, character: 3 }, sourcemapLines), { line: 2, character: 3 }

    // Walk-back: when the queried line has no usable mapping, scan preceding
    // lines for the nearest 4-tuple.  Without this, sparse stage-1 maps
    // (Hera→Civet) yield raw TS line numbers for ~82% of generated lines,
    // which then land past EOF in the .hera source.
    it "walks back to previous line when current line is empty", ->
      sourcemapLines: SourcemapLines := [[[0, 0, 5, 0]], []]
      assert.deepEqual remapPosition({ line: 1, character: 3 }, sourcemapLines),
        { line: 5, character: 0 }

    it "walks back across multiple unmapped lines", ->
      sourcemapLines: SourcemapLines := [[[0, 0, 5, 2]], [], [], []]
      assert.deepEqual remapPosition({ line: 3, character: 7 }, sourcemapLines),
        { line: 5, character: 2 }

    it "uses last 4-tuple on the preceding mapped line", ->
      // line 0 has two 4-tuples; the second (col 10 in generated) is closer
      sourcemapLines: SourcemapLines := [[[0, 0, 1, 0], [10, 0, 0, 7]], []]
      assert.deepEqual remapPosition({ line: 1, character: 0 }, sourcemapLines),
        { line: 0, character: 7 }

    it "skips column-delta-only lines while walking back", ->
      sourcemapLines: SourcemapLines := [[[0, 0, 5, 0]], [[4]], []]
      assert.deepEqual remapPosition({ line: 2, character: 0 }, sourcemapLines),
        { line: 5, character: 0 }

    it "walks back when current line has only column-delta entries", ->
      sourcemapLines: SourcemapLines := [[[0, 0, 5, 0]], [[4]]]
      assert.deepEqual remapPosition({ line: 1, character: 4 }, sourcemapLines),
        { line: 5, character: 0 }

    it "returns position as-is when no preceding line has a 4-tuple", ->
      pos := { line: 5, character: 3 }
      sourcemapLines: SourcemapLines := [[], [], [[4]]]
      assert.deepEqual remapPosition(pos, sourcemapLines), pos

    it "walks back from out-of-bounds line to nearest mapped line", ->
      sourcemapLines: SourcemapLines := [[[0, 0, 9, 1]]]
      assert.deepEqual remapPosition({ line: 50, character: 3 }, sourcemapLines),
        { line: 9, character: 1 }

  describe "remapPositionStrict", ->
    // Strict variant must NOT walk back to preceding lines — the
    // semantic-tokens path relies on `undefined` to drop tokens whose
    // generated position lives in compiler-synthesized code with no
    // direct mapping.  Walk-back is exclusive to `remapPosition`.
    it "returns undefined when the queried line has no mapping entries", ->
      assert.equal remapPositionStrict({ line: 0, character: 5 }, [[]]), undefined

    it "returns undefined when the queried line has only column-delta entries", ->
      assert.equal remapPositionStrict({ line: 0, character: 4 }, [[[4]]]), undefined

    it "returns undefined when the line index is out of bounds", ->
      assert.equal remapPositionStrict({ line: 5, character: 3 }, [[]]), undefined

    it "does NOT walk back to preceding lines (unlike remapPosition)", ->
      sourcemapLines: SourcemapLines := [[[0, 0, 5, 0]], []]
      // remapPosition would walk back to {line:5, character:0}
      assert.equal remapPositionStrict({ line: 1, character: 3 }, sourcemapLines), undefined

    it "remaps position via a same-line 4-tuple", ->
      pos := { line: 0, character: 0 }
      assert.deepEqual remapPositionStrict(pos, [[[0, 0, 2, 5]]]), { line: 2, character: 5 }

    it "applies character offset beyond mapping anchor", ->
      pos := { line: 0, character: 4 }
      assert.deepEqual remapPositionStrict(pos, [[[0, 0, 1, 3]]]), { line: 1, character: 7 }

  describe "remapRange", ->
    it "remaps both start and end positions", ->
      sourcemapLines: SourcemapLines := [[[0, 0, 5, 2]]]
      range :=
        start: { line: 0, character: 0 }
        end: { line: 0, character: 3 }
      assert.deepEqual remapRange(range, sourcemapLines),
        start: { line: 5, character: 2 }
        end: { line: 5, character: 5 }

    it "passes through range unchanged when no sourcemapLines", ->
      range :=
        start: { line: 1, character: 2 }
        end: { line: 1, character: 8 }
      assert.deepEqual remapRange(range), range

  describe "flattenDiagnosticMessageText", ->
    it "returns string directly when given a string", ->
      assert.equal flattenDiagnosticMessageText("hello"), "hello"

    it "returns empty string for undefined", ->
      assert.equal flattenDiagnosticMessageText(undefined), ""

    it "returns messageText from DiagnosticMessageChain at top level", ->
      assert.equal flattenDiagnosticMessageText({ messageText: "type error" }), "type error"

    it "appends nested chain messages with indentation", ->
      diag :=
        messageText: "outer"
        next: [{ messageText: "inner" }]
      assert.equal flattenDiagnosticMessageText(diag), "outer\n  inner"

    it "handles deeply nested chains", ->
      diag :=
        messageText: "level0"
        next: [{ messageText: "level1", next: [{ messageText: "level2" }] }]
      assert.equal flattenDiagnosticMessageText(diag), "level0\n  level1\n    level2"

    it "appends multiple siblings at same nesting level", ->
      diag :=
        messageText: "root"
        next: [{ messageText: "child1" }, { messageText: "child2" }]
      assert.equal flattenDiagnosticMessageText(diag), "root\n  child1\n  child2"
