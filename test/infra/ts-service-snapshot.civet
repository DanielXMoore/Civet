// Unit tests for source/ts-service/snapshot.civet — fullDiffTextChangeRange
// + the Snap factory.  Lives in root mocha so coverage of
// `source/ts-service/snapshot.civet` comes from the standalone .civet
// compilation path only (see scripts/coverage-check.civet for the gating
// split).

{ describe, it } from mocha
assert from assert

{ Snap, fullDiffTextChangeRange } from "../../source/ts-service/snapshot.civet"

describe "fullDiffTextChangeRange", ->
  it "returns undefined for identical texts", ->
    assert.equal fullDiffTextChangeRange("hello", "hello"), undefined
    assert.equal fullDiffTextChangeRange("", ""), undefined

  it "covers a single insertion in the middle", ->
    range := fullDiffTextChangeRange "ac", "abc"
    assert range
    // start = 1 (first divergence), length = 0 (nothing removed),
    // newLength = 1 (one char added).
    assert.deepEqual range, { span: { start: 1, length: 0 }, newLength: 1 }

  it "covers a single deletion in the middle", ->
    range := fullDiffTextChangeRange "abc", "ac"
    assert range
    assert.deepEqual range, { span: { start: 1, length: 1 }, newLength: 0 }

  it "covers a replacement", ->
    range := fullDiffTextChangeRange "aXc", "aYc"
    assert range
    assert.deepEqual range, { span: { start: 1, length: 1 }, newLength: 1 }

  it "covers a pure prefix extension", ->
    range := fullDiffTextChangeRange "abc", "Xabc"
    assert range
    assert.deepEqual range, { span: { start: 0, length: 0 }, newLength: 1 }

  it "returns undefined when the shorter text is a prefix of the longer one", ->
    // Algorithm only scans the common-prefix length; pure-suffix edits
    // fall through to no-change.  TS treats the missing range as "do a
    // full re-parse" — a correctness-preserving conservative result.
    assert.equal fullDiffTextChangeRange("abc", "abcX"), undefined
    assert.equal fullDiffTextChangeRange("abcdef", "abc"), undefined

  it "covers truncation from the start", ->
    range := fullDiffTextChangeRange "abcdef", "def"
    assert range
    assert.deepEqual range, { span: { start: 0, length: 3 }, newLength: 0 }

describe "Snap", ->
  it "getText respects start/end slicing", ->
    s := Snap "hello world"
    assert.equal s.getText(0, 5), "hello"
    assert.equal s.getText(6, 11), "world"

  it "getLength returns full text length", ->
    assert.equal Snap("abc").getLength(), 3
    assert.equal Snap("").getLength(), 0

  it "getChangeRange returns a span for differing snapshots", ->
    oldSnap := Snap "hello"
    newSnap := Snap "help!"
    range := newSnap.getChangeRange oldSnap
    assert range
    assert.equal range.span.start, 3
    assert.equal range.span.length, 2
    assert.equal range.newLength, 2

  it "getChangeRange returns undefined when texts match", ->
    a := Snap "same"
    b := Snap "same"
    assert.equal b.getChangeRange(a), undefined

  it "getChangeRange caches per old snapshot (idempotent)", ->
    oldSnap := Snap "abc"
    newSnap := Snap "abXc"
    first := newSnap.getChangeRange oldSnap
    second := newSnap.getChangeRange oldSnap
    // Cache returns the same object reference on the second call.
    assert.strictEqual first, second
