import assert from assert

describe "bundler adapters: esbuild", ->
  let esbuildPlugin: Function
  before ->
    @timeout 10000
    { default: esbuildPlugin } = await import("../../source/unplugin/esbuild.civet")

  it "exports a function", ->
    assert.equal typeof esbuildPlugin, "function"

  it "factory returns a plugin with correct name", ->
    assert.equal esbuildPlugin({ts: "civet"}).name, "unplugin-civet"

