// webpack and rspack follow the webpack plugin interface:
// the factory returns { apply(compiler) } rather than a named plugin object.
describe "bundler adapters: webpack", ->
  let webpackPlugin: Function
  before ->
    { default: webpackPlugin } = await import("../../source/unplugin/webpack.civet")

  it "exports a function", ->
    assert.equal typeof webpackPlugin, "function"

  it "factory returns an object with an apply method", ->
    assert.equal typeof webpackPlugin({ts: "civet"}).apply, "function"

describe "bundler adapters: rspack", ->
  let rspackPlugin: Function
  before ->
    { default: rspackPlugin } = await import("../../source/unplugin/rspack.civet")

  it "exports a function", ->
    assert.equal typeof rspackPlugin, "function"

  it "factory returns an object with an apply method", ->
    assert.equal typeof rspackPlugin({ts: "civet"}).apply, "function"

describe "bundler adapters: astro", ->
  let astroPlugin: Function
  before ->
    { default: astroPlugin } = await import("../../source/unplugin/astro.civet")

  it "exports a function", ->
    assert.equal typeof astroPlugin, "function"

  it "factory returns an astro integration with correct name", ->
    assert.equal astroPlugin({}).name, "@danielx/civet"

  it "integration has astro:config:setup hook", ->
    assert.equal typeof astroPlugin({}).hooks["astro:config:setup"], "function"
