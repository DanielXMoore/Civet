import assert from assert
{
  getExtensionFromPath
  getTranspiledExtensionsFromPath
  removeExtension
  remapFileName
} from ../../source/ts-service/path.civet

describe "ts-service path helpers", ->
  it "extracts and removes extensions", ->
    assert.equal getExtensionFromPath("foo/bar/baz.js"), ".js"
    assert.equal getExtensionFromPath("foo/bar/baz"), ""
    assert.deepEqual getTranspiledExtensionsFromPath("foo/bar/baz.civet.tsx"), [".civet", ".tsx"]
    assert.equal getTranspiledExtensionsFromPath("foo/bar/baz"), undefined
    assert.equal removeExtension("foo/bar/baz.civet.tsx"), "foo/bar/baz.civet"

  it "remaps transpiled filenames back to matching source filenames", ->
    transpilers := new Map()
    transpilers.set ".civet",
      extension: ".civet"
      target: ".tsx"
      compile: (_path: string, _source: string) =>
        code: ""
    assert.equal remapFileName("foo/bar/baz.civet.tsx", transpilers), "foo/bar/baz.civet"
    assert.equal remapFileName("foo/bar/baz.ts", transpilers), "foo/bar/baz.ts"
    assert.equal remapFileName("foo/bar/baz.civet.js", transpilers), "foo/bar/baz.civet.js"
