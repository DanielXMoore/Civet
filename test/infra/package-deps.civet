import assert from assert
import { readFileSync } from fs
import { join } from path

pkgPath := join process.cwd(), 'package.json'
pkg := JSON.parse readFileSync(pkgPath, 'utf8')

// Tiny semver subset — `x.y.z` against `^x.y.z`.  Avoids a direct
// `semver` dep just for one consistency check.
function satisfiesCaret(version: string, range: string): boolean
  return false unless range.startsWith '^'
  base := range.slice 1
  [vMaj, vMin, vPatch] := version.split('.').map (n) => Number(n)
  [bMaj, bMin, bPatch] := base.split('.').map (n) => Number(n)
  return false if [vMaj, vMin, vPatch, bMaj, bMin, bPatch].some Number.isNaN
  if bMaj > 0
    return false unless vMaj is bMaj
    return false if vMin < bMin
    return false if vMin is bMin and vPatch < bPatch
    return true
  if bMin > 0
    return false unless vMaj is 0 and vMin is bMin
    return false if vPatch < bPatch
    return true
  return vMaj is 0 and vMin is 0 and vPatch is bPatch

describe "package.json dep consistency", ->
  it "devDependencies['@danielx/hera'] satisfies peerDependencies['@danielx/hera']", ->
    devVersion := pkg.devDependencies['@danielx/hera']
    peerRange := pkg.peerDependencies['@danielx/hera']
    assert devVersion, "expected @danielx/hera devDependency"
    assert peerRange, "expected @danielx/hera peerDependency"
    assert satisfiesCaret(devVersion, peerRange),
      `dev pin @danielx/hera@${devVersion} does not satisfy peer range '${peerRange}' — bump the peer range or drop the dev pin`
