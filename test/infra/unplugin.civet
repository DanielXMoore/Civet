    await plugin.buildStart()

describe "unplugin: resolveId implicit extension", ->
  let tmpDir2: string
  fileNum2 .= 0
  before ->
    tmpDir2 = path.join tmpdir(), "civet-unplugin-implicit-" + Math.random().toString(36).substring(2)
    await mkdir tmpDir2, { recursive: true }
  after ->
    await rm tmpDir2, { recursive: true, force: true }

  it "resolveId uses implicit .civet extension for existing file", ->
    filePath := path.join tmpDir2, `file-${fileNum2++}.civet`
    await writeFile filePath, "x := 1\n"
    plugin := rawPlugin { ts: 'civet', config: false, implicitExtension: true }, minMeta
    ctx := { ...nullContext, ...plugin }
    await plugin.buildStart.call ctx
    // Resolve an id that has no .civet extension, using the civet file as importer
    idWithoutCivet := path.basename(filePath)[...-6]  // strip .civet
    result := plugin.resolveId.call ctx, "./" + idWithoutCivet + ".jsx", filePath, { isEntry: false }
    assert result, "resolveId should resolve via implicit .civet extension"
    assert (result as string).endsWith(".civet.jsx"),
      `expected .civet.jsx but got: ${result}`

describe "unplugin: resolveId vite scan mode", ->
  let tmpDirScan: string
  before ->
    tmpDirScan = path.join tmpdir(), "civet-unplugin-scan-" + Math.random().toString(36).substring(2)
    await mkdir tmpDirScan, { recursive: true }
  after ->
    await rm tmpDirScan, { recursive: true, force: true }

  it "resolveId in vite scan mode returns \\0-prefixed id", ->
    viteMeta := { framework: 'vite' as const }
    plugin := rawPlugin { ts: 'civet', config: false }, viteMeta
    ctx := { ...nullContext, ...plugin }
    await plugin.buildStart.call ctx
    civetFile := path.join tmpDirScan, "scan-target.civet"
    await writeFile civetFile, "x := 1\n"
    // Vite passes `scan` in resolveId options; unplugin's typed signature omits it
    result := plugin.resolveId.call ctx, civetFile + ".jsx", undefined, { isEntry: false, scan: true } as { isEntry: boolean }
    assert result, "should return a result"
    assert (result as string).startsWith('\0'),
      `expected \\0-prefixed id in scan mode, got: ${result}`

describe "unplugin: vite 7 skipWorker", ->
  it "vite.config with vite 7 sets skipWorker, blocking ?worker requests", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    await plugin.buildStart()
    viteConfig: any := { root: '', build: {} }
    // Simulate Vite 7 plugin context with meta.viteVersion
    //@ts-ignore
    plugin.vite.config.call { meta: { viteVersion: '7.0.0' } }, viteConfig
    // skipWorker is now true; ?worker suffix should be blocked
    assert.equal plugin.loadInclude("foo.civet.jsx?worker"), false

describe "unplugin: vite.transformIndexHtml()", ->
  it "rewrites .civet src attribute in script tags", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    html := '<html><body><script src="./main.civet"></script></body></html>'
    result := (plugin.vite.transformIndexHtml as (html: string) => string) html
    assert result.includes('./main.civet.jsx?transform'),
      `expected src rewrite, got: ${result}`

  it "leaves non-civet src unchanged", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    html := '<html><body><script src="./main.js"></script></body></html>'
    result := (plugin.vite.transformIndexHtml as (html: string) => string) html
    assert result.includes('./main.js'), "non-civet src should be unchanged"
    assert !result.includes('?transform'), "should not add ?transform"

  it "leaves plain HTML comments without script tags unchanged", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    html := '<!-- just a comment --><p>hello</p>'
    result := (plugin.vite.transformIndexHtml as (html: string) => string) html
    assert !result.includes('?transform'), "comment without script should not produce ?transform"

  it "leaves non-script tags unchanged", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    html := '<link href="./style.css"><img src="./photo.civet">'
    result := (plugin.vite.transformIndexHtml as (html: string) => string) html
    assert !result.includes('?transform'), "non-script tags should not be rewritten"

describe "unplugin: vite.handleHotUpdate()", ->
  it "returns undefined for non-civet files (early return)", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    modules: any[] := [{ id: 'foo.ts' }]
    server: any :=
      moduleGraph:
        getModulesByFile: -> null
        onFileChange: ->
    handleHotUpdate := plugin.vite.handleHotUpdate as (ctx: { file: string, server: unknown, modules: unknown[] }) => unknown
    result := handleHotUpdate { file: 'foo.ts', server, modules }
    assert.equal result, undefined

  it "returns modules for civet files with no server entry", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    modules: any[] := []
    server: any :=
      moduleGraph:
        getModulesByFile: -> null
        onFileChange: ->
    handleHotUpdate := plugin.vite.handleHotUpdate as (ctx: { file: string, server: unknown, modules: unknown[] }) => unknown
    result := handleHotUpdate { file: '/app/main.civet', server, modules }
    assert.deepEqual result, modules

  it "returns merged modules for civet files with server entry", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    existingModule: any := { id: 'main.civet.jsx' }
    fileModules := new Set [existingModule]
    modules: any[] := []
    server: any :=
      moduleGraph:
        getModulesByFile: -> fileModules
        onFileChange: ->
    handleHotUpdate := plugin.vite.handleHotUpdate as (ctx: { file: string, server: unknown, modules: unknown[] }) => unknown
    result := handleHotUpdate { file: '/app/main.civet', server, modules }
    assert Array.isArray(result), "result should be array"
    assert (result as any[]).includes(existingModule), "should include file modules"

describe "unplugin: tsc string typecheck", ->
  let tmpDirTsc: string
  before ->
    tmpDirTsc = path.join tmpdir(), "civet-tsc-str-" + Math.random().toString(36).substring(2)
    await mkdir tmpDirTsc, { recursive: true }
  after ->
    await rm tmpDirTsc, { recursive: true, force: true }

  it "typecheck: passes through empty/missing package.json", ->
    // During module resolution tsc walks up directories looking for
    // package.json; for parents that don't have one, the readFile
    // interceptor receives undefined content. Covers
    // \`return json unless json\` at unplugin.civet:287.
    @timeout 15000
    // Create an empty package.json alongside a deep source dir so TS
    // probes multiple levels.
    emptyPkgDir := path.join tmpDirTsc, "empty-pkg"
    await mkdir emptyPkgDir, { recursive: true }
    await writeFile path.join(emptyPkgDir, "package.json"), ""
    file := path.join emptyPkgDir, "src.civet"
    await writeFile file, "x := 1\n"

    plugin := rawPlugin {
      ts: 'tsc'
      config: false
      typecheck: true
      tsConfig: {
        rootDir: emptyPkgDir
        files: [ file ]
        compilerOptions: { moduleResolution: "NodeNext", module: "NodeNext" }
      }
    }, { framework: 'esbuild' }
    ctx := { ...nullContext, ...plugin }
    plugin.esbuild.config { outdir: testOutDir }

    origError := console.error
    console.error = ->
    try
      await plugin.buildStart.call ctx
      await plugin.load.call ctx, file + ".jsx"
      await plugin.buildEnd.call ctx
    catch
      // TypeScript may emit diagnostics about the empty package.json;
      // we only care that the readFile interceptor's empty-json path ran.
    finally
      console.error = origError

  it "typecheck: leaves non-string entries in files array untouched", ->
    // The mogrify helper is defensive against non-string items in
    // tsconfig.json's "files" array (spec says string[], but user
    // might pass anything via tsConfig). Covers the
    // `return item unless item <? "string"` guard at unplugin.civet:216.
    @timeout 15000
    subDir := path.join tmpDirTsc, "nonstring-files"
    await mkdir subDir, { recursive: true }
    file := path.join subDir, "in.civet"
    await writeFile file, "x := 1\n"

    plugin := rawPlugin {
      ts: 'tsc'
      config: false
      typecheck: true
      tsConfig: {
        rootDir: subDir
        files: [ file, 42 ]
      }
    }, { framework: 'esbuild' }
    ctx := { ...nullContext, ...plugin }
    plugin.esbuild.config { outdir: testOutDir }

    origError := console.error
    console.error = ->
    try
      await plugin.buildStart.call ctx
      await plugin.buildEnd.call ctx
    catch
      // tsc may error on the malformed entry; we only care that mogrify ran
    finally
      console.error = origError

  it "typecheck: mogrifies .civet entries in package.json imports", ->
    @timeout 15000
    // Use a fresh subdir so the test's package.json is what tsc picks up.
    subDir := path.join tmpDirTsc, "pkg-imports-dir"
    await mkdir subDir, { recursive: true }
    file := path.join subDir, "pkg-imports.civet"
    await writeFile file, "import './foo.civet.tsx'\n"
    pkgFile := path.join subDir, "package.json"
    await writeFile pkgFile, JSON.stringify
      name: "civet-unplugin-pkg-imports-test"
      type: "module"
      imports: { "#local": "./foo.civet" }

    plugin := rawPlugin {
      ts: 'tsc'
      config: false
      typecheck: true
      tsConfig: {
        rootDir: subDir
        files: [ file ]
        compilerOptions: { moduleResolution: "NodeNext", module: "NodeNext" }
      }
    }, { framework: 'esbuild' }
    ctx := { ...nullContext, ...plugin }
    plugin.esbuild.config { outdir: testOutDir }

    origError := console.error
    console.error = ->
    try
      await plugin.buildStart.call ctx
      await plugin.load.call ctx, file + ".jsx"
      await plugin.buildEnd.call ctx
    catch
      // ignore — we only care that the imports.recurse branch ran
    finally
      console.error = origError

  it "typecheck: fails with plural 's' on multiple type errors", ->
    @timeout 15000
    // Two distinct type errors in one file → diagnostics.length > 1
    file := path.join tmpDirTsc, "err-plural.civet"
    await writeFile file, "x: number := 'not a number'\ny: string := 42\n"
    rootDir := tmpDirTsc

    plugin := rawPlugin {
      ts: 'tsc'
      config: false
      typecheck: true
      tsConfig: { rootDir, files: [ file ] }
    }, { framework: 'esbuild' }
    ctx := { ...nullContext, ...plugin }
    plugin.esbuild.config { outdir: testOutDir }

    origError := console.error
    console.error = ->
    let errMsg
    try
      await plugin.buildStart.call ctx
      await plugin.load.call ctx, file + ".jsx"
      await plugin.buildEnd.call ctx
    catch error
      errMsg = (error as Error).message
    finally
      console.error = origError
    assert errMsg, "build should have aborted"
    assert.match errMsg, /diagnostics/, "plural 'diagnostics' expected in message"

  it "typecheck: 'error' string fails on type errors", ->
    @timeout 15000
    fileWithTSError := path.join tmpDirTsc, "err.civet"
    await writeFile fileWithTSError, "x: number := 'not a number'\n"
    rootDir := tmpDirTsc

    plugin := rawPlugin {
      ts: 'tsc'
      config: false
      typecheck: 'error'
      tsConfig: {
        rootDir
        files: [ fileWithTSError ]
      }
    }, { framework: 'esbuild' }
    ctx := { ...nullContext, ...plugin }
    plugin.esbuild.config { outdir: testOutDir }

    origError := console.error
    console.error = ->
    let errored
    try
      await plugin.buildStart.call ctx
      await plugin.load.call ctx, fileWithTSError + ".jsx"
      await plugin.buildEnd.call ctx
    catch error
      assert error <? Error
      assert.match error.message, /Aborting build/
      errored = true
    finally
      console.error = origError
    assert errored, "build should have aborted due to type error"

  it "typecheck: compound string covers all category keywords", ->
    @timeout 15000
    file := path.join tmpDirTsc, "err-compound.civet"
    await writeFile file, "x: number := 'not a number'\n"
    rootDir := tmpDirTsc

    plugin := rawPlugin {
      ts: 'tsc'
      config: false
      typecheck: 'error,warning,suggestion,message'
      tsConfig: {
        rootDir
        files: [ file ]
      }
    }, { framework: 'esbuild' }
    ctx := { ...nullContext, ...plugin }
    plugin.esbuild.config { outdir: testOutDir }

    origError := console.error
    console.error = ->
    let errored
    try
      await plugin.buildStart.call ctx
      await plugin.load.call ctx, file + ".jsx"
      await plugin.buildEnd.call ctx
    catch error
      assert error <? Error
      errored = true
    finally
      console.error = origError
    assert errored, "build should have aborted"

  it "typecheck: 'all' string fails on any diagnostics", ->
    @timeout 15000
    fileWithTSError2 := path.join tmpDirTsc, "err2.civet"
    await writeFile fileWithTSError2, "x: number := 'not a number'\n"
    rootDir := tmpDirTsc

    plugin := rawPlugin {
      ts: 'tsc'
      config: false
      typecheck: 'all'
      tsConfig: {
        rootDir
        files: [ fileWithTSError2 ]
      }
    }, { framework: 'esbuild' }
    ctx := { ...nullContext, ...plugin }
    plugin.esbuild.config { outdir: testOutDir }

    origError := console.error
    console.error = ->
    let errored
    try
      await plugin.buildStart.call ctx
      await plugin.load.call ctx, fileWithTSError2 + ".jsx"
      await plugin.buildEnd.call ctx
    catch error
      assert error <? Error
      errored = true
    finally
      console.error = origError
    assert errored, "build should have aborted with typecheck:'all'"

  it "typecheck: passes through diagnostics on non-civet files unchanged", ->
    @timeout 15000
    // .ts file is read via systemReadFile, never goes through civet.compile,
    // so sourceMaps.get() returns undefined. Covers the `!sourceMap` branch.
    subDir := path.join tmpDirTsc, "mixed-ts"
    await mkdir subDir, { recursive: true }
    tsFile := path.join subDir, "helper.ts"
    await writeFile tsFile, "export const x: number = 'oops';\n"
    civetFile := path.join subDir, "main.civet"
    await writeFile civetFile, "{ x } from './helper.ts'\nconsole.log x\n"

    plugin := rawPlugin {
      ts: 'tsc'
      config: false
      typecheck: true
      tsConfig: { rootDir: subDir, files: [ civetFile ] }
    }, { framework: 'esbuild' }
    ctx := { ...nullContext, ...plugin }
    plugin.esbuild.config { outdir: testOutDir }

    origError := console.error
    console.error = ->
    let errored
    try
      await plugin.buildStart.call ctx
      await plugin.load.call ctx, civetFile + ".jsx"
      await plugin.buildEnd.call ctx
    catch error
      errored = true
    finally
      console.error = origError
    assert errored, "build should have aborted from .ts file type error"

describe "unplugin: vinxi (SolidStart) support", ->
  let tmpDirVinxi: string
  fileNumVinxi .= 0
  before ->
    tmpDirVinxi = path.join tmpdir(), "civet-unplugin-vinxi-" + Math.random().toString(36).substring(2)
    await mkdir tmpDirVinxi, { recursive: true }
  after ->
    await rm tmpDirVinxi, { recursive: true, force: true }

  function makeCivetRoute(content: string)
    filePath := path.join tmpDirVinxi, `route-${fileNumVinxi++}.civet`
    await writeFile filePath, content
    filePath

  // Mimics a vinxi BaseFileSystemRouter subclass: toRoute reads the route
  // file synchronously (like vinxi's analyzeModule) and records what it saw.
  function makeVinxiRouter()
    reads: string[] := []
    routes := {
      toRoute: (src: string) ->
        reads.push fsSync.readFileSync src, 'utf8'
        { path: '/', src }
    }
    { reads, routes, router: { internals: { routes } } }

  it "vite.config with a vinxi router stops appending the output extension", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    await plugin.buildStart()
    civetFile := await makeCivetRoute "x := 1\n"
    //@ts-expect-error vinxi vite config
    plugin.vite.config { router: {}, build: {} }
    // Routers without a usable toRoute (e.g. handler-only) are skipped
    //@ts-expect-error vinxi vite config
    plugin.vite.config { router: { internals: { routes: {} } }, build: {} }
    //@ts-expect-error build context
    result := plugin.resolveId civetFile, undefined, {}
    assert result, "resolveId should resolve the file"
    assert result.endsWith('.civet'),
      `expected plain .civet id (vinxi manifest keys use it), got: ${result}`

  it "patches toRoute so route analysis sees compiled TSX", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    civetFile := await makeCivetRoute "count := 42\nexport default -> count\n"
    { reads, routes, router } := makeVinxiRouter()
    //@ts-expect-error vinxi vite config
    plugin.vite.config { router, build: {} }
    route := await routes.toRoute civetFile
    assert.deepEqual route, { path: '/', src: civetFile }
    assert.equal reads.length, 1, "analysis read the route once"
    assert reads[0].includes('export default'), "compiled output keeps the export"
    assert !reads[0].includes(':='), `analysis saw raw Civet: ${reads[0]}`
    // Second route on the same plugin instance reuses the cached config load
    civetFile2 := await makeCivetRoute "export default -> 'two'\n"
    await routes.toRoute civetFile2
    assert.equal reads.length, 2
    assert !reads[1].includes(':='), `analysis saw raw Civet: ${reads[1]}`

  it "passes through reads of other files during analysis", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    civetFile := await makeCivetRoute "x := 1\n"
    sibling := path.join tmpDirVinxi, "sibling.json"
    await writeFile sibling, '{"answer": 42}'
    reads: string[] := []
    routes := {
      toRoute: (src: string) ->
        reads.push fsSync.readFileSync src, 'utf8'
        reads.push fsSync.readFileSync sibling, 'utf8'
        { path: '/', src }
    }
    //@ts-expect-error vinxi vite config
    plugin.vite.config { router: { internals: { routes } }, build: {} }
    await routes.toRoute civetFile
    assert !reads[0].includes(':='), "route read sees compiled output"
    assert.equal reads[1], '{"answer": 42}',
      "reads of other files during analysis are untouched"

  it "restores fs.readFileSync after analysis", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    raw := "x := 1\n"
    civetFile := await makeCivetRoute raw
    { routes, router } := makeVinxiRouter()
    //@ts-expect-error vinxi vite config
    plugin.vite.config { router, build: {} }
    await routes.toRoute civetFile
    assert.equal fsSync.readFileSync(civetFile, 'utf8'), raw,
      "reads outside toRoute should see the raw source again"

  it "leaves non-civet routes alone", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    tsxFile := path.join tmpDirVinxi, "plain.tsx"
    raw := "export default () => 1\n"
    await writeFile tsxFile, raw
    { reads, routes, router } := makeVinxiRouter()
    //@ts-expect-error vinxi vite config
    plugin.vite.config { router, build: {} }
    await routes.toRoute tsxFile
    assert.equal reads[0], raw, "non-civet routes pass through unchanged"

  it "only patches a router once", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    { routes, router } := makeVinxiRouter()
    //@ts-expect-error vinxi vite config
    plugin.vite.config { router, build: {} }
    patched := routes.toRoute
    //@ts-expect-error vinxi vite config
    plugin.vite.config { router, build: {} }
    assert.equal routes.toRoute, patched, "second config call should not re-wrap"

  it "patches routers found on globalThis.app at construction", ->
    // `vinxi build` materializes routes in the parent process without
    // running any vite hook; the plugin patches via globalThis.app on the
    // first microtask after construction.
    { reads, routes, router } := makeVinxiRouter()
    original := routes.toRoute
    (globalThis as any).app = { config: { routers: [{ name: 'static' }, router] } }
    try
      rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
      await Promise.resolve()
      assert.notEqual routes.toRoute, original, "toRoute should be wrapped"
      civetFile := await makeCivetRoute "y := 2\n"
      await routes.toRoute civetFile
      assert !reads[0].includes(':='), `analysis saw raw Civet: ${reads[0]}`
    finally
      delete (globalThis as any).app

  it "warns when ts: 'preserve' is used with vinxi", ->
    logCalls: string[] := []
    orig := console.log
    console.log = (msg: string) => logCalls.push(msg)
    try
      plugin := rawPlugin { ts: 'preserve', config: false }, { framework: 'vite' }
      //@ts-expect-error vinxi vite config
      plugin.vite.config { router: {}, build: {} }
      assert logCalls.some((m) => /WARNING.*preserve.*vinxi/i.test(m)),
        `expected ts:'preserve' warning, got: ${JSON.stringify logCalls}`
    finally
      console.log = orig

  it "handleHotUpdate matches vinxi ids without output extension", ->
    plugin := rawPlugin { ts: 'civet', config: false }, { framework: 'vite' }
    //@ts-expect-error vinxi vite config
    plugin.vite.config { router: {}, build: {} }
    let askedFor: string?
    server: any :=
      moduleGraph:
        getModulesByFile: (id: string) ->
          askedFor = id
          null
        onFileChange: ->
    handleHotUpdate := plugin.vite.handleHotUpdate as (ctx: { file: string, server: unknown, modules: unknown[] }) => unknown
    handleHotUpdate { file: '/app/main.civet', server, modules: [] }
    assert askedFor, "getModulesByFile should be queried"
    assert askedFor!.endsWith('/main.civet'),
      `expected extensionless vinxi id, got: ${askedFor}`

describe "unplugin: emitDeclaration without esbuild outdir", ->
  it "buildEnd throws if emitDeclaration is true and esbuild outdir is not set", ->
    @timeout 15000
    plugin := rawPlugin {
      ts: 'tsc'
      config: false
      emitDeclaration: true
    }, { framework: 'esbuild' }
    ctx := { ...nullContext, ...plugin }
    // Set esbuild options WITHOUT outdir (only outfile)
    plugin.esbuild.config { outfile: path.join testOutDir, 'bundle.js' }

    // Load a file so fsMap is populated
    filePath := path.join tmpdir(), "civet-emit-nodest-" + Date.now() + ".civet"
    await writeFile filePath, "x: number := 5\n"

    origError := console.error
    console.error = ->
    let errored
    try
      await plugin.buildStart.call ctx
      await plugin.load.call ctx, filePath + ".jsx"
      await plugin.buildEnd.call ctx
    catch error
      assert error <? Error
      assert.match error.message, /emitDeclaration.*outdir|outdir.*emitDeclaration/i
      errored = true
    finally
      console.error = origError
      await rm filePath, { force: true }
    assert errored, "should throw when emitDeclaration is true without outdir"
