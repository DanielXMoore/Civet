assert from assert
{
  assert: civetAssert
  inplacePrepend
  makeLeftHandSideExpression
  replaceNodes
  startsWithPredicate
} from ../../source/parser/util.civet

describe "replaceNodes", ->
  it "passes through null root unchanged", ->
    assert.equal replaceNodes(null, (=> true), (n) => n), null

  it "replaces a bare leaf node when predicate matches", ->
    leaf := { type: "Ref", name: "x" }
    replaced := replaceNodes leaf,
      (n) => n.type is "Ref"
      (n) => ({ ...n, name: "y" })
    assert.equal replaced.name, "y"

  it "stops iteration when an array slot is null", ->
    unreachable := { type: "B" }
    arr := [{ type: "A" }, null, unreachable]
    seen: unknown[] .= []
    replaceNodes arr,
      (n) =>
        seen.push n
        false
      (n) => n
    assert not seen.includes(unreachable), "items after null should not be visited"

describe "startsWithPredicate", ->
  it "returns undefined for an array of only skippable whitespace", ->
    input := ["\n", "  ", "\t"]
    assert.equal startsWithPredicate(input, (=> true)), undefined

describe "makeLeftHandSideExpression", ->
  it "returns a parenthesized expression without rewrapping", ->
    fn := {
      type: "ArrowFunction"
      parenthesized: true
      children: ["(", "body", ")"]
    }
    assert.equal makeLeftHandSideExpression(fn), fn

describe "civet assert util", ->
  it "passes truthy value", ->
    civetAssert true, "should not throw"
    civetAssert 1, "should not throw"
    civetAssert "x", "should not throw"

  it "throws on falsy value", ->
    assert.throws (=> civetAssert false, "msg here"), /Assertion failed \[msg here\]/
    assert.throws (=> civetAssert null, "n"), /Assertion failed \[n\]/
    assert.throws (=> civetAssert undefined, "u"), /Assertion failed \[u\]/
    assert.throws (=> civetAssert 0, "z"), /Assertion failed \[z\]/

  it "equal passes when equal", ->
    civetAssert.equal 1, 1, "should not throw"
    civetAssert.equal "x", "x", "should not throw"

  it "equal throws when unequal", ->
    assert.throws (=> civetAssert.equal 1, 2, "nope"), /Assertion failed \[nope\]: 1 !== 2/
    assert.throws (=> civetAssert.equal "a", "b", "str"), /Assertion failed \[str\]: a !== b/

  it "notEqual passes when unequal", ->
    civetAssert.notEqual 1, 2, "should not throw"
    civetAssert.notEqual "x", "y", "should not throw"

  it "notEqual throws when equal", ->
    assert.throws (=> civetAssert.notEqual 1, 1, "same"), /Assertion failed \[same\]: 1 === 1/

  it "notNull passes on non-null values", ->
    civetAssert.notNull 0, "zero is fine"
    civetAssert.notNull "", "empty string is fine"
    civetAssert.notNull false, "false is fine"
    civetAssert.notNull {}, "obj is fine"

  it "notNull throws on null/undefined", ->
    assert.throws (=> civetAssert.notNull null, "n"), /Assertion failed \[n\]: got null/
    assert.throws (=> civetAssert.notNull undefined, "u"), /Assertion failed \[u\]: got null/

describe "inplacePrepend", ->
  it "no-ops on undefined prefix", ->
    node := [1, 2, 3]
    inplacePrepend(undefined, node)
    assert.deepEqual node, [1, 2, 3], "node should be untouched"

  it "no-ops on empty array prefix", ->
    node := [1, 2, 3]
    inplacePrepend([], node)
    assert.deepEqual node, [1, 2, 3], "empty array prefix should be skipped"

  it "unshifts truthy prefix into an array node", ->
    node := [1, 2, 3]
    inplacePrepend("pre", node)
    assert.deepEqual node, ["pre", 1, 2, 3]

  it "unshifts prefix into children of a parent node", ->
    node := { type: "X", children: [1, 2] }
    inplacePrepend("pre", node)
    assert.deepEqual node.children, ["pre", 1, 2]
